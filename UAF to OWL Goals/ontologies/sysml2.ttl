@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gufo: <http://purl.org/nemo/gufo#> .
@prefix sysml2: <http://omg.org/spec/SysML2#> .

<http://omg.org/spec/SysML2> rdf:type owl:Ontology ;
    owl:imports <http://purl.org/nemo/gufo> ;
    rdfs:label "SysML v2 Standard Systems Library" ;
    rdfs:comment "Normative OWL ontology representing the standard SysML v2 Standard Systems Library." .

# --- Base Classes ---
sysml2:Element rdf:type owl:Class ;
    rdfs:subClassOf gufo:AbstractIndividual ;
    rdfs:label "Element" .

sysml2:Definition rdf:type owl:Class ;
    rdfs:subClassOf sysml2:Element ;
    rdfs:label "Definition" .

sysml2:Usage rdf:type owl:Class ;
    rdfs:subClassOf sysml2:Element ;
    rdfs:label "Usage" .

# --- Annotation Property ---
sysml2:canonical rdf:type owl:AnnotationProperty ;
    rdfs:label "canonical" ;
    rdfs:comment "FQN path of the standard element." .


sysml2:pkg-actions rdf:type owl:Class ;
    rdfs:subClassOf sysml2:Definition ;
    rdfs:label "Actions" ;
    sysml2:canonical "Actions" ;
    rdfs:comment "Standard package Actions defined in Actions.sysml" .

sysml2:def-action rdf:type owl:Class ;
    rdfs:subClassOf sysml2:def-performance ;
    rdfs:label "Action" ;
    sysml2:canonical "Actions::Action" ;
    rdfs:comment "Standard SysML v2 / KerML action def: Action" .

sysml2:def-sendaction rdf:type owl:Class ;
    rdfs:subClassOf sysml2:def-action ;
    rdfs:label "SendAction" ;
    sysml2:canonical "Actions::SendAction" ;
