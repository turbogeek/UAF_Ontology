@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix uafsml: <http://purl.org/uaf/uafsml#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bmm: <http://www.omg.org/spec/BMM/> .
@prefix sumo: <http://www.ontologyportal.org/SUMO.owl#> .
@prefix sr: <http://purl.org/uaf/example/sounding_rocket#> .

<http://purl.org/uaf/example/sounding_rocket> rdf:type owl:Ontology ;
    owl:imports <http://purl.org/uaf/bridge> ;
    rdfs:label "Three-Stage Sounding Rocket Systems Engineering & Enterprise Model" ;
    rdfs:comment "A complete UAFSML model instance representing a 3-stage sounding rocket with payload variants and support enterprise structures." .

# =========================================================================
# 1. Strategic Viewpoint (UAF Strategic Domain / St)
# =========================================================================

# Strategic Capability (St-Tx)
sr:HighAltitudeResearchCapability rdf:type owl:Class ;
    rdfs:label "High Altitude Atmospheric Research Capability" ;
    rdfs:subClassOf uafsml:Usage ;
    rdfs:comment "The strategic capability to perform measurements and scientific sampling in the mesosphere and lower thermosphere (80-150km)." .

# Measure of Effectiveness / Strategic Constraint (St-Ct)
sr:ApogeeTargetMoE rdf:type owl:Class ;
    rdfs:label "Target Apogee MoE" ;
    rdfs:subClassOf uafsml:Usage ;
    rdfs:comment "Constraint defining the target apogee threshold of at least 150km." .

# =========================================================================
# 2. Operational Viewpoint (UAF Operational Domain / Op)
# =========================================================================

# Operational Performer (Op-Tx)
sr:TelemetryReceiverRole rdf:type owl:Class ;
    rdfs:label "Telemetry Ground Operator" ;
    rdfs:subClassOf uafsml:Usage ;
    rdfs:comment "Logical operational role responsible for monitoring ground telemetry signals." .

# Operational Activity (Op-Pr)
sr:ProcessTelemetryData rdf:type owl:Class ;
    rdfs:label "Process Ascent Telemetry" ;
    rdfs:subClassOf uafsml:Usage ;
    rdfs:comment "Operational activity representing the real-time decoding, logging, and plotting of downlinked data." .

# =========================================================================
# 3. Resources Viewpoint (UAF Resources Domain / Rs)
# =========================================================================

# Resource Taxonomy (Rs-Tx)
sr:SolidRocketMotor rdf:type owl:Class ;
    rdfs:label "Solid Rocket Motor Class" ;
    rdfs:subClassOf sumo:Device ;
    rdfs:comment "High-thrust ammonium perchlorate composite propellant booster class." .

# =========================================================================
# 4. Standards Viewpoint (UAF Standards Domain / Sd)
# =========================================================================

# Standard Definition (Sd-Tx)
sr:ISO-9001-ManufacturingStandard rdf:type owl:Class ;
    rdfs:label "ISO 9001 Quality Standard" ;
    rdfs:subClassOf uafsml:Usage ;
    rdfs:comment "International standard for quality management systems governing booster manufacturing processes." .

# =========================================================================
# 5. Requirements Viewpoint (UAF Requirements / Req)
# =========================================================================

sr:req-payload_mass rdf:type owl:NamedIndividual , uafsml:Requirement ;
    rdfs:label "Requirement: Minimum Payload Capacity" ;
    rdfs:comment "The sounding rocket propulsion system must be capable of lifting a payload mass of at least 15kg to apogee." ;
    uafsml:id "SR-REQ-001" .

sr:req-apogee rdf:type owl:NamedIndividual , uafsml:Requirement ;
    rdfs:label "Requirement: Target Apogee Altitude" ;
    rdfs:comment "The vehicle must achieve a minimum apogee altitude of 150km under nominal weather conditions." ;
    uafsml:id "SR-REQ-002" ;
    sr:refines sr:HighAltitudeResearchCapability .

# =========================================================================
# 6. Payload Definition Classes
# =========================================================================

sr:WeatherPayload rdf:type owl:Class ;
    rdfs:label "Weather Payload" ;
    rdfs:subClassOf sumo:Device , uafsml:Usage ;
    rdfs:comment "Payload instrument suite for measuring atmospheric pressure, wind, and humidity." .

sr:SolarWeatherSensor rdf:type owl:Class ;
    rdfs:label "Solar Weather Sensor" ;
    rdfs:subClassOf sumo:Device , uafsml:Usage ;
    rdfs:comment "Payload instrument for monitoring solar radiation, magnetosphere, and ionosphere disturbances." .

sr:AtmosphericChemicalAnalyzer rdf:type owl:Class ;
    rdfs:label "Atmospheric Chemical Analyzer" ;
    rdfs:subClassOf sumo:Device , uafsml:Usage ;
    rdfs:comment "Spectrometer payload for analyzing ozone concentration and trace gases in the upper atmosphere." .

# =========================================================================
# 7. Sounding Rocket Physical Architecture & Actual Instances (UAF Actual / Ac)
# =========================================================================

# The main rocket system (Ac-Sr)
sr:inst-sounding_rocket rdf:type owl:NamedIndividual , uafsml:Usage ;
    rdfs:label "Sounding Rocket System" ;
    rdfs:comment "Three-stage modular research rocket." ;
    rdf:type sumo:Vehicle ;
    uafsml:canonical "SoundingRocketModel::SoundingRocket" ;
    sr:satisfies sr:req-apogee ;
    sr:satisfies sr:req-payload_mass .

# Stage 1 Booster (Solid Fuel Propulsion)
sr:inst-stage_1_booster rdf:type owl:NamedIndividual , uafsml:Usage ;
    rdfs:label "Stage 1 Solid Booster" ;
    rdfs:comment "First-stage high-thrust solid rocket booster for initial lift-off." ;
    rdf:type sumo:Device , sr:SolidRocketMotor ;
    uafsml:canonical "SoundingRocketModel::SoundingRocket::Stage1Booster" .

# Stage 2 Mid-Stage (Liquid Fuel Propulsion)
sr:inst-stage_2_mid_stage rdf:type owl:NamedIndividual , uafsml:Usage ;
    rdfs:label "Stage 2 Mid-Stage" ;
    rdfs:comment "Second-stage liquid propellent mid-stage." ;
    rdf:type sumo:Device ;
    uafsml:canonical "SoundingRocketModel::SoundingRocket::Stage2MidStage" .

# Stage 3 Upper-Stage (Cold Gas Attitude Control + Booster)
sr:inst-stage_3_upper_stage rdf:type owl:NamedIndividual , uafsml:Usage ;
    rdfs:label "Stage 3 Upper-Stage" ;
    rdfs:comment "Third-stage upper rocket body for final orbit/apogee alignment." ;
    rdf:type sumo:Device ;
    uafsml:canonical "SoundingRocketModel::SoundingRocket::Stage3UpperStage" .

# Payload Section
sr:inst-payload_section rdf:type owl:NamedIndividual , uafsml:Usage ;
    rdfs:label "Payload Nose Cone" ;
    rdfs:comment "Aero-fairing payload section housing sensors." ;
    rdf:type sumo:Device ;
    uafsml:canonical "SoundingRocketModel::SoundingRocket::PayloadSection" .

# Recovery Parachute
sr:inst-recovery_parachute rdf:type owl:NamedIndividual , uafsml:Usage ;
    rdfs:label "Recovery Parachute System" ;
    rdfs:comment "Barometric dual-deployment parachute recovery system." ;
    rdf:type sumo:Device ;
    uafsml:canonical "SoundingRocketModel::SoundingRocket::RecoverySystem" .

# Active Weather Payload individual
sr:inst-active_weather_payload rdf:type owl:NamedIndividual , sr:WeatherPayload ;
    rdfs:label "Active Atmospheric Weather Sensor" ;
    rdfs:comment "The deployed weather sensor payload." ;
    uafsml:canonical "SoundingRocketModel::SoundingRocket::PayloadSection::WeatherPayload" .

# Staging composition linkages (contains)
sr:inst-sounding_rocket sr:contains sr:inst-stage_1_booster .
sr:inst-sounding_rocket sr:contains sr:inst-stage_2_mid_stage .
sr:inst-sounding_rocket sr:contains sr:inst-stage_3_upper_stage .
sr:inst-sounding_rocket sr:contains sr:inst-payload_section .
sr:inst-sounding_rocket sr:contains sr:inst-recovery_parachute .
sr:inst-payload_section sr:contains sr:inst-active_weather_payload .

sr:contains rdf:type owl:ObjectProperty ;
    rdfs:label "contains" .

# =========================================================================
# 8. Ground & Communications Systems Mappings
# =========================================================================

sr:inst-ground_telemetry_station rdf:type owl:NamedIndividual , uafsml:Usage ;
    rdfs:label "Ground Telemetry Control Station" ;
    rdfs:comment "Base operations ground station for data collection and tracking." ;
    rdf:type sumo:Device , sr:TelemetryReceiverRole ;
    uafsml:canonical "SoundingRocketModel::GroundStation" .

sr:inst-rocket_telemetry_transmitter rdf:type owl:NamedIndividual , uafsml:Usage ;
    rdfs:label "S-Band Telemetry Transmitter" ;
    rdfs:comment "High-altitude radio telemetry transmitter." ;
    rdf:type sumo:Device ;
    uafsml:canonical "SoundingRocketModel::SoundingRocket::TelemetryTransmitter" .

# Downlink association
sr:inst-rocket_telemetry_transmitter sr:connectedTo sr:inst-ground_telemetry_station .

sr:connectedTo rdf:type owl:ObjectProperty ;
    rdfs:label "connected to" .

# =========================================================================
# 9. Enterprise Architecture & Personnel Hierarchy (W3C ORG)
# =========================================================================

sr:org-rocket_enterprise rdf:type owl:NamedIndividual , org:Organization ;
    rdfs:label "Sounding Rocket Aerospace Enterprise" ;
    rdfs:comment "Corporate entity responsible for design, launch, and quality auditing." .

sr:org-design_division rdf:type owl:NamedIndividual , org:OrganizationalUnit ;
    rdfs:label "Design Division" ;
    org:subOrganizationOf sr:org-rocket_enterprise .

sr:org-manufacturing_division rdf:type owl:NamedIndividual , org:OrganizationalUnit ;
    rdfs:label "Propulsion Manufacturing Team" ;
    org:subOrganizationOf sr:org-rocket_enterprise ;
    sr:conformsTo sr:ISO-9001-ManufacturingStandard .

sr:org-quality_assurance_division rdf:type owl:NamedIndividual , org:OrganizationalUnit ;
    rdfs:label "Quality Assurance Department" ;
    org:subOrganizationOf sr:org-rocket_enterprise .

sr:org-quality_control_division rdf:type owl:NamedIndividual , org:OrganizationalUnit ;
    rdfs:label "Quality Control Inspectors" ;
    org:subOrganizationOf sr:org-quality_assurance_division .

sr:org-ground_systems_crew rdf:type owl:NamedIndividual , org:OrganizationalUnit ;
    rdfs:label "Ground Operations & Launch Crew" ;
    org:subOrganizationOf sr:org-rocket_enterprise .

# Personnel post assignments
sr:post-lead_aerospace_architect rdf:type owl:NamedIndividual , org:Post ;
    rdfs:label "Lead Systems Architect" ;
    org:postIn sr:org-design_division .

sr:post-qa_manager rdf:type owl:NamedIndividual , org:Post ;
    rdfs:label "QA Compliance Director" ;
    org:postIn sr:org-quality_assurance_division .

# =========================================================================
# 10. Strategic Mission Goals (OMG BMM)
# =========================================================================

sr:goal-orbit_insertion rdf:type owl:NamedIndividual , bmm:Goal ;
    rdfs:label "Goal: Complete Stage Separation & High-Altitude Apogee" ;
    rdfs:comment "Target apogee of 150km for scientific observation." ;
    bmm:channelsEffortsTowards sr:inst-sounding_rocket .

sr:policy-iso9001_compliance rdf:type owl:NamedIndividual , bmm:BusinessPolicy ;
    rdfs:label "Quality Standard: ISO 9001:2015" ;
    rdfs:comment "Standard quality management guidelines governing booster manufacturing." ;
    bmm:governs sr:org-quality_assurance_division .

# =========================================================================
# 11. Traceability Properties
# =========================================================================

sr:satisfies rdf:type owl:ObjectProperty ;
    rdfs:label "satisfies" .

sr:refines rdf:type owl:ObjectProperty ;
    rdfs:label "refines" .

sr:conformsTo rdf:type owl:ObjectProperty ;
    rdfs:label "conforms to" .

bmm:governs rdf:type owl:ObjectProperty ;
    rdfs:label "governs" .
