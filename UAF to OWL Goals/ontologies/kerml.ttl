@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gufo: <http://purl.org/nemo/gufo#> .
@prefix kerml: <http://omg.org/spec/KerML#> .

<http://omg.org/spec/KerML> rdf:type owl:Ontology ;
    owl:imports <http://purl.org/nemo/gufo> ;
    rdfs:label "KerML Standard Library" ;
    rdfs:comment "Normative OWL ontology representing the standard KerML Standard Library." .

# --- Base Classes ---
kerml:Element rdf:type owl:Class ;
    rdfs:subClassOf gufo:AbstractIndividual ;
    rdfs:label "Element" .

kerml:Definition rdf:type owl:Class ;
    rdfs:subClassOf kerml:Element ;
    rdfs:label "Definition" .

kerml:Usage rdf:type owl:Class ;
    rdfs:subClassOf kerml:Element ;
    rdfs:label "Usage" .

# --- Annotation Property ---
kerml:canonical rdf:type owl:AnnotationProperty ;
    rdfs:label "canonical" ;
    rdfs:comment "FQN path of the standard element." .


kerml:pkg-collections rdf:type owl:Class ;
    rdfs:subClassOf kerml:Definition ;
    rdfs:label "Collections" ;
    kerml:canonical "Collections" ;
    rdfs:comment "Standard package Collections defined in Collections.kerml" .

kerml:pkg-scalarvalues rdf:type owl:Class ;
