            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "SecurityClassificationKind" ;
            rdfs:comment "A type that defines acceptable values for the security category (SC) of an information system, where the acceptable values for potential impact are low, moderate, or high." .

uaf:SecurityIntegrity rdf:type owl:Class ;
