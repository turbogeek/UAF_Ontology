            uaf:xmiID "_18_0_2_8f40297_1425638118252_773300_38556" ;
            rdfs:subClassOf gufo:Object ;
            rdfs:label "RiskOwner" ;
            rdfs:comment "Mapped from UML/XMI metamodel element RiskOwner." .

