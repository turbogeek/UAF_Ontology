@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gufo: <http://purl.org/nemo/gufo#> .
@prefix uaf: <http://purl.org/uaf/ontology#> .

<http://purl.org/uaf/ontology> rdf:type owl:Ontology ;
                               owl:imports <http://purl.org/nemo/gufo#> ;
                               rdfs:label "UAF Ontology Mapping" ;
                               rdfs:comment "A formal mapping of the Unified Architecture Framework (UAF) Domain Metamodel (DMM) to OWL 2 DL using gUFO." .

# ==========================================
# Traceability & Grid Annotation Properties
# ==========================================

uaf:xmiID rdf:type owl:AnnotationProperty ;
          rdfs:label "XMI ID" ;
          rdfs:comment "The original unique identifier of the element in the UAF Domain Metamodel (DMM) or UML Profile." .

uaf:gridAspect rdf:type owl:AnnotationProperty ;
               rdfs:label "Grid Aspect" ;
               rdfs:comment "The row in the UAF Grid (Aspect) that this element is ideally modeled in (e.g. Strategic, Operational, Resources)." .

uaf:gridViewpoint rdf:type owl:AnnotationProperty ;
                  rdfs:label "Grid Viewpoint" ;
                  rdfs:comment "The column in the UAF Grid (Viewpoint) that this element is ideally modeled in (e.g. Taxonomy, Structure, Connectivity)." .

# ==========================================
# Generated UAF DMM Classes & Stereotypes
# ==========================================

uaf:metaconstraint rdf:type owl:Class ;
            uaf:xmiID "30ce5738-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf gufo:Object ;
            rdfs:label "metaconstraint" ;
            rdfs:comment "The metaProperty stereotype is applied to dependencies between stereotypes to visually model constraints on the stereotypes' underlying UML metatypes.  The umlRole Tag relates to a role on an existing meta-level association between metatypes (for example ownedAttribute on the association between Class and Property).  This allows us to model the equivalent of redefines/subsets which has been used in the M3, for example, without creating unnecessary and unwanted associations between the stereotypes (as subset and redefine can only be used through inheritance and we're using extends).  It has nothing to do with creating aggregation between stereotypes (i.e. tagged values). Tagged values are shown as associations in the profile." .

uaf:metarelationship rdf:type owl:Class ;
            uaf:xmiID "34507964-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf gufo:Object ;
            rdfs:label "metarelationship" ;
            rdfs:comment "Mapped from UML/XMI metamodel element metarelationship." .

