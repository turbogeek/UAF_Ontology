            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:SecurityMeasurement ;
            rdfs:label "SecurityAvailability" ;
            rdfs:comment "Details the potential impact on organization or individuals if the information is not available to those who need to access it." .

uaf:SecurityCategory rdf:type owl:Class ;
            uaf:xmiID "_17_0_5_1_7d40257_1404470104413_789932_28489" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:MeasurementSet ;
            rdfs:label "SecurityCategory" ;
            rdfs:comment "The security categories that have been determined for each type of information processed, stored, or transmitted by those information systems. The generalized format for expressing the security category (SC) of an information system is:  SC information system = {(confidentiality, impact), (integrity, impact), (availability, impact)}." .

uaf:SecurityClassification rdf:type owl:Class ;
            uaf:xmiID "_17_0_5_1_7d40257_1401446561664_534467_31631" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:SecurityMeasurement ;
            rdfs:label "SecurityClassification" ;
            rdfs:comment "Details a classification for the exchange." .

uaf:SecurityClassificationKind rdf:type owl:Class ;
