uaf:OperationalAgent rdf:type owl:Class ;
            uaf:xmiID "359f66d2-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:OperationalAsset ;
            rdfs:subClassOf uaf:SubjectOfOperationalConstraint ;
            rdfs:subClassOf uaf:CapableElement ;
            rdfs:subClassOf uaf:Desirer ;
            rdfs:label "OperationalAgent" ;
            rdfs:comment "An abstract type grouping OperationalArchitecture and OperationalPerformer." .

uaf:OperationalRole rdf:type owl:Class ;
            uaf:xmiID "34028033-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:subClassOf uaf:LocationHolder ;
            rdfs:subClassOf uaf:AssetRole ;
            rdfs:subClassOf uaf:OpposableElement ;
            rdfs:label "OperationalRole" ;
            rdfs:comment "Usage of a OperationalPerformer or OperationalArchitecture in the context of another OperationalPerformer or OperationalArchitecture. Creates a whole-part relationship." .

uaf:OperationalArchitecture rdf:type owl:Class ;
            uaf:xmiID "356d0c7a-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:OperationalAgent ;
            rdfs:subClassOf uaf:Architecture ;
            rdfs:label "OperationalArchitecture" ;
            rdfs:comment "An element used to denote a model of the Architecture, described from the Operational perspective." .

uaf:KnownResource rdf:type owl:Class ;
            uaf:xmiID "31a72aa1-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:OperationalPerformer ;
            rdfs:subClassOf uaf:ResourcePerformer ;
            rdfs:label "KnownResource" ;
            rdfs:comment "Asserts that a known ResourcePerformer constrains the implementation of the OperationalPerformer that plays the role in the OperationalArchitecture." .

uaf:OperationalPerformer rdf:type owl:Class ;
            uaf:xmiID "30889b06-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:OperationalAgent ;
            rdfs:subClassOf uaf:OpposableElement ;
            rdfs:label "OperationalPerformer" ;
            rdfs:comment "A logical agent that IsCapableToPerform OperationalActivities which produce, consume and process Resources." .

uaf:ProblemDomain rdf:type owl:Class ;
            uaf:xmiID "357a5291-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:OperationalRole ;
            rdfs:label "ProblemDomain" ;
            rdfs:comment "A property associated with an OperationalArchitecture, used to specify the scope of the problem." .

uaf:OperationalPort rdf:type owl:Class ;
            uaf:xmiID "_18_1_8f40297_1435914745584_781100_33657" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "OperationalPort" ;
            rdfs:comment "An interaction point for an OperationalAgent through which it can interact with the outside environment and which is defined by an OperationalInterface." .

uaf:OperationalMethod rdf:type owl:Class ;
            uaf:xmiID "3504d509-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "OperationalMethod" ;
            rdfs:comment "A behavioral feature of an OperationalAgent whose behavior is specified in an OperationalActivity." .

uaf:OperationalParameter rdf:type owl:Class ;
            uaf:xmiID "35832ca9-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "OperationalParameter" ;
            rdfs:comment "An element that represents inputs and outputs of an OperationalActivity. It is typed by an OperationalExchangeItem." .

uaf:ArbitraryConnector rdf:type owl:Class ;
            uaf:xmiID "35aab214-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ArbitraryConnector" ;
            rdfs:comment "Represents a visual indication of a connection used in high level operational concept diagrams." .

uaf:ConceptItem rdf:type owl:Class ;
            uaf:xmiID "3322806f-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "ConceptItem" ;
            rdfs:comment "An abstract type which represents some part played by an asset or location in a HighLevelOperationalConcept." .

uaf:ConceptRole rdf:type owl:Class ;
            uaf:xmiID "30541da6-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ConceptRole" ;
            rdfs:comment "Usage of a ConceptItem in the context of a HighLevelOperationalConcept." .

uaf:HighLevelOperationalConcept rdf:type owl:Class ;
            uaf:xmiID "33844ee5-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "HighLevelOperationalConcept" ;
            rdfs:comment "Describes the Resources and Locations required to meet an operational scenario from an integrated systems point of view. It is used to communicate overall quantitative and qualitative system characteristics to stakeholders." .

uaf:OperationalConnector rdf:type owl:Class ;
            uaf:xmiID "35551756-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:AssetRole ;
            rdfs:label "OperationalConnector" ;
            rdfs:comment "A Connector that goes between OperationalRoles representing a need to exchange Resources. It can carry a number of OperationalExchanges." .

uaf:OperationalInterface rdf:type owl:Class ;
            uaf:xmiID "_18_1_8f40297_1435914499463_133120_33564" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "OperationalInterface" ;
            rdfs:comment "A declaration that specifies a contract between the OperationalPerformer it is related to, and any other OperationalPerformers it can interact with." .

uaf:OperationalExchange rdf:type owl:Class ;
            uaf:xmiID "342ceaf1-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:Exchange ;
            rdfs:subClassOf uaf:SubjectOfOperationalConstraint ;
            rdfs:label "OperationalExchange" ;
            rdfs:comment "Asserts that a flow can exist between OperationalPerformers (i.e. flows of information, people, materiel, or energy)." .

uaf:OperationalExchangeItem rdf:type owl:Class ;
            uaf:xmiID "2f9365a2-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:Resource ;
            rdfs:label "OperationalExchangeItem" ;
            rdfs:comment "An abstract grouping for elements that defines the types of elements that can be exchanged between OperationalPerformers and conveyed by an OperationalExchange." .

uaf:OperationalSignal rdf:type owl:Class ;
            uaf:xmiID "_18_4_1_8f40297_1481140625503_482272_34899" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:OperationalExchangeItem ;
            rdfs:subClassOf uaf:SubjectOfOperationalConstraint ;
            rdfs:label "OperationalSignal" ;
            rdfs:comment "An OperationalSignal is a specification of a kind of communication between operational performers in which a reaction is asynchronously triggered in the receiver without a reply." .

uaf:OperationalSignalProperty rdf:type owl:Class ;
            uaf:xmiID "_18_4_1_8f40297_1481140716440_285636_35026" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "OperationalSignalProperty" ;
            rdfs:comment "A property of an OperationalSignal typed by OperationalExchangeItem. It enables OperationalExchangeItem e.g. OperationalInformation to be passed as arguments of the OperationalSignal." .

uaf:OperationalConstraint rdf:type owl:Class ;
            uaf:xmiID "34efc63c-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:Rule ;
            rdfs:label "OperationalConstraint" ;
            rdfs:comment "A Rule governing an operational architecture element i.e. OperationalPerformer, OperationalActivity, OperationalInformation etc." .

uaf:SubjectOfOperationalConstraint rdf:type owl:Class ;
            uaf:xmiID "334c28cf-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "SubjectOfOperationalConstraint" ;
            rdfs:comment "An abstract grouping of elements that can be the subject of an OperationalConstraint. Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:OperationalInformation rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1416228922899_678875_39326" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Information" ;
            rdfs:subClassOf uaf:OperationalAsset ;
            rdfs:subClassOf uaf:OperationalExchangeItem ;
            rdfs:subClassOf uaf:SubjectOfOperationalConstraint ;
            rdfs:subClassOf uaf:ServiceExchangeItem ;
            rdfs:label "OperationalInformation" ;
            rdfs:comment "An item of information that flows between OperationalPerformers and is produced and consumed by the OperationalActivities that the OperationalPerformers are capable to perform (see IsCapableToPerform)." .

uaf:OperationalMessage rdf:type owl:Class ;
            uaf:xmiID "2fe815ad-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Sequences" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "OperationalMessage" ;
            rdfs:comment "Message for use in an operational interaction scenario which carries any of the subtypes of OperationalExchange." .

uaf:OperationalActivity rdf:type owl:Class ;
            uaf:xmiID "31a3f627-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:Activity ;
            rdfs:subClassOf uaf:SubjectOfOperationalConstraint ;
            rdfs:label "OperationalActivity" ;
            rdfs:comment "An Activity that captures a logical process, specified independently of how the process is carried out." .

uaf:OperationalActivityAction rdf:type owl:Class ;
            uaf:xmiID "33973ab1-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "OperationalActivityAction" ;
            rdfs:comment "A call of an OperationalActivity in the context of another OperationalActivity." .

uaf:OperationalActivityEdge rdf:type owl:Class ;
            uaf:xmiID "314b4f1b-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "OperationalActivityEdge" ;
            rdfs:comment "Abstract grouping for OperationalControlFlow and OperationalObjectFlow." .

uaf:OperationalControlFlow rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_7d40257_1418074745282_691493_47931" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:OperationalActivityEdge ;
            rdfs:label "OperationalControlFlow" ;
            rdfs:comment "An ActivityEdge that shows the flow of control between OperationalActivityActions." .

uaf:OperationalObjectFlow rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_7d40257_1418075069590_858624_47965" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:OperationalActivityEdge ;
            rdfs:label "OperationalObjectFlow" ;
            rdfs:comment "An ActivityEdge that shows the flow of Resources (objects/information) between OperationalActivityActions." .

uaf:StandardOperationalActivity rdf:type owl:Class ;
            uaf:xmiID "31af4164-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:OperationalActivity ;
            rdfs:label "StandardOperationalActivity" ;
            rdfs:comment "A sub-type of OperationalActivity that is a standard operating procedure." .

uaf:MissionThread rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1715343229020_314427_761" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:OperationalActivity ;
            rdfs:label "MissionThread" ;
            rdfs:comment "A sequence of end-to-end mission tasks, activities, and events presented as a series of steps to achieve a mission. (OUSD(R&E))" .

uaf:MissionTask rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1715446003784_450342_4667" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:MissionThread ;
            rdfs:label "MissionTask" ;
            rdfs:comment "A clearly defined activity specifically to be assigned to system, person, or organization that must be completed" .

uaf:MissionTaskAction rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1718797758195_110952_1332" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:OperationalActivityAction ;
            rdfs:label "MissionTaskAction" ;
            rdfs:comment "The usage of a MissionTask within a MissionThread" .

uaf:OperationalStateDescription rdf:type owl:Class ;
            uaf:xmiID "317fa56a-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Operational" ;
            uaf:gridViewpoint "States" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "OperationalStateDescription" ;
            rdfs:comment "A state machine describing the behavior of a OperationalPerformer, depicting how the OperationalPerformer responds to various events and the actions." .

uaf:ActualState rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1414663148101_789117_34983" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "ActualState" ;
            rdfs:comment "Abstract element that applies temporal extent to a set of elements realized as Instance Specifications." .

uaf:ISO8601DateTime rdf:type owl:Class ;
            uaf:xmiID "346bf02c-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "ISO8601DateTime" ;
            rdfs:comment "A date and time specified in the ISO8601 date-time format including timezone designator (TZD): YYYY-MM-DDThh:mm:ssTZD." .

uaf:OpposableElement rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1716377602269_428279_48" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "OpposableElement" ;
            rdfs:comment "A type of element that is categorized to allow for it to have an Opposes relationship to some other opposable element  Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:DesignationKind rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1716896179142_987310_4066" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "DesignationKind" ;
            rdfs:comment "An enumerated type that defines the kind of structural element with respect to purpose, intent and capabilities of that element" .

uaf:Exchange rdf:type owl:Class ;
            uaf:xmiID "34f125e1-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:subClassOf uaf:SubjectOfSecurityConstraint ;
            rdfs:label "Exchange" ;
            rdfs:comment "Abstract grouping for OperationalExchanges and ResourceExchanges that exchange Resources." .

uaf:Resource rdf:type owl:Class ;
            uaf:xmiID "3303fb60-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "Resource" ;
            rdfs:comment "Abstract element grouping for all elements that can be conveyed by an Exchange." .

uaf:Rule rdf:type owl:Class ;
            uaf:xmiID "30d4720c-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Rule" ;
            rdfs:comment "An abstract grouping for all types of constraint (i.e. an OperationalConstraint could detail the rules of accountancy best practice). Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:Activity rdf:type owl:Class ;
            uaf:xmiID "2f0900d5-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:AffectableElement ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "Activity" ;
            rdfs:comment "An abstract element that represents a behavior or process (i.e. a Function or OperationalActivity) that can be performed by a Performer." .

uaf:CapableElement rdf:type owl:Class ;
            uaf:xmiID "34388459-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "CapableElement" ;
            rdfs:comment "An abstract type that represents a structural element that can exhibit capabilities. Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:IsCapableToPerform rdf:type owl:Class ;
            uaf:xmiID "34814d19-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "IsCapableToPerform" ;
            rdfs:comment "An Abstraction relationship defining the traceability between the structural elements to the Activities that they can perform." .

uaf:PerformsInContext rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1416386669738_707679_37085" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "PerformsInContext" ;
            rdfs:comment "An abstraction relationship that relates an OperationalAction to a OperationalRole, or a FunctionAction to a ResourceRole. It indicates that the action can be carried out by the role when used in a specific context or configuration." .

uaf:Implements rdf:type owl:Class ;
            uaf:xmiID "34025920-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Traceability" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Implements" ;
            rdfs:comment "An abstraction relationship that defines how an element in the upper layer of abstraction is implemented by a semantically equivalent element (for example tracing the Functions to the OperationalActivities) in the lower level of abstraction." .

uaf:ArchitecturalReference rdf:type owl:Class ;
            uaf:xmiID "34248707-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Traceability" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ArchitecturalReference" ;
            rdfs:comment "A dependency relationship that specifies that one architectural description refers to another." .

uaf:Sequence rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1614516570513_11288_112" ;
            uaf:gridViewpoint "Traceability" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Sequence" ;
            rdfs:comment "A dependency relationship that asserts one Individual's temporal extent is completely before the temporal extent of another." .

uaf:ComparesTo rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1614959075411_410110_3372" ;
            uaf:gridViewpoint "Traceability" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ComparesTo" ;
            rdfs:comment "An abstraction relationship relating the effect that is achieved with the originally expected DesiredEffect. Providing a means of comparison, between the expectation of the desirer and the actual result." .

uaf:Alias rdf:type owl:Class ;
            uaf:xmiID "31b0c818-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Information" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Alias" ;
            rdfs:comment "A metamodel Artifact used to define an alternative name for an element." .

uaf:Definition rdf:type owl:Class ;
            uaf:xmiID "348bd3ff-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Information" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Definition" ;
            rdfs:comment "A comment containing a description of an element in the architecture." .

uaf:SameAs rdf:type owl:Class ;
            uaf:xmiID "33c1311e-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Information" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "SameAs" ;
            rdfs:comment "A dependency relationship that asserts that two elements refer to the same real-world thing." .

uaf:ArchitectureMetadata rdf:type owl:Class ;
            uaf:xmiID "32eddc1c-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Information" ;
            rdfs:subClassOf uaf:Metadata ;
            rdfs:label "ArchitectureMetadata" ;
            rdfs:comment "Information associated with an ArchitecturalDescription, that supplements the standard set of tags used to summarize the Architecture. It states things like what methodology was used, notation, etc." .

uaf:Information rdf:type owl:Class ;
            uaf:xmiID "306a16da-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Information" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Information" ;
            rdfs:comment "A comment that describes the state of an item of interest in any medium or form -- and is communicated or received." .

uaf:Metadata rdf:type owl:Class ;
            uaf:xmiID "34036a9e-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Information" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Metadata" ;
            rdfs:comment "A comment that can be applied to any element in the architecture. The attributes associated with this element details the relationship between the element and its related dublinCoreElement, metaDataScheme, category and name. This allows the element to be referenced using the Semantic Web." .

uaf:InformationModel rdf:type owl:Class ;
            uaf:xmiID "2ff50db0-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Information" ;
            rdfs:subClassOf uaf:SubjectOfOperationalConstraint ;
            rdfs:subClassOf uaf:SubjectOfResourceConstraint ;
            rdfs:label "InformationModel" ;
            rdfs:comment "A structural specification of information types, showing relationships between them. The type of information captured in the InformationModel is described using the enumeration InformationModelKind (Conceptual, Logical, and Physical)." .

uaf:Opposes rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1715446583749_116683_4776" ;
            uaf:gridViewpoint "Information" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Opposes" ;
            rdfs:comment "A tuple that indicates an open clash between two opposing groups (or individuals). This means that elements in the model are fighting against each other or are providing strong resistance to progress towards some goals. Note to entry: By individual this does not indicate instances in the model." .

uaf:ConflictsWith rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1715446750318_907999_4902" ;
            uaf:gridViewpoint "Information" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ConflictsWith" ;
            rdfs:comment "An annotation that indicates UAF elements acting against or in opposition to each other. This means that there are elements in the model that disagree about something important or are incompatible with each other in some way" .

uaf:ServicePort rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1416818435393_438470_32322" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ServicePort" ;
            rdfs:comment "An interaction point for a Service through which it can interact with the outside environment and which is defined by a ServiceInterface." .

uaf:ServiceRole rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_7d40257_1418145038430_818062_54949" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:subClassOf uaf:AssetRole ;
            rdfs:label "ServiceRole" ;
            rdfs:comment "Usage of a Service in the context of another Service. Creates a whole-part relationship." .

uaf:ServiceMethod rdf:type owl:Class ;
            uaf:xmiID "32bf7896-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ServiceMethod" ;
            rdfs:comment "A behavioral feature of a Service whose behavior is specified in a ServiceFunction." .

uaf:ServiceParameter rdf:type owl:Class ;
            uaf:xmiID "3253be90-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ServiceParameter" ;
            rdfs:comment "An element that represents inputs and outputs of a ServiceFunction, represents inputs and outputs of a Service." .

uaf:Service rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1415801571649_354495_37435" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:subClassOf uaf:VersionedElement ;
            rdfs:subClassOf uaf:CapableElement ;
            rdfs:subClassOf uaf:Asset ;
            rdfs:label "Service" ;
            rdfs:comment "A mechanism to enable access to one or more capabilities, where the access is provided using a prescribed service interface and is exercised consistent with service constraints and policies." .

uaf:ServiceArchitecture rdf:type owl:Class ;
            uaf:xmiID "_19_0_2_3ed017a_1582889231859_97154_75630" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:Service ;
            rdfs:subClassOf uaf:Architecture ;
            rdfs:label "ServiceArchitecture" ;
            rdfs:comment "An element used to denote a model of the Architecture, described from the Services perspective." .

uaf:ServiceConnector rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_7d40257_1418146579804_692867_55236" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:AssetRole ;
            rdfs:label "ServiceConnector" ;
            rdfs:comment "A channel for exchange between two Services. Where one acts as the consumer of the other." .

uaf:ServiceInterface rdf:type owl:Class ;
            uaf:xmiID "306dc08a-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "ServiceInterface" ;
            rdfs:comment "A contract that defines the ServiceMethods and ServiceSignals that the Service realizes." .

uaf:ServiceExchange rdf:type owl:Class ;
            uaf:xmiID "_19_0_2_3ed017a_1582875903378_904854_72716" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:Exchange ;
            rdfs:label "ServiceExchange" ;
            rdfs:comment "Asserts that a flow can exist between Services (i.e. flows of information, people, materiel, or energy)." .

uaf:ServiceExchangeItem rdf:type owl:Class ;
            uaf:xmiID "_19_0_2_3ed017a_1582876450944_722648_72836" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:Resource ;
            rdfs:subClassOf uaf:Resource ;
            rdfs:label "ServiceExchangeItem" ;
            rdfs:comment "An abstract grouping for elements that defines the types of elements that can be exchanged between Services and conveyed by a ServiceExchange." .

uaf:ServiceSignalProperty rdf:type owl:Class ;
            uaf:xmiID "_19_0_2_3ed017a_1599568589519_799045_40745" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ServiceSignalProperty" ;
            rdfs:comment "A property of a ServiceSignal typed by ServiceExchangeItem. It enables ServiceExchangeItem e.g. OperationalInformation to be passed as arguments of the ServiceSignal." .

uaf:ServiceSignal rdf:type owl:Class ;
            uaf:xmiID "_19_0_2_3ed017a_1599568469290_137584_40594" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:ServiceExchangeItem ;
            rdfs:label "ServiceSignal" ;
            rdfs:comment "A specification of a kind of communication between Services in which a reaction is asynchronously triggered in the receiver without a reply." .

uaf:ServicePolicy rdf:type owl:Class ;
            uaf:xmiID "309a4f27-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:Rule ;
            rdfs:label "ServicePolicy" ;
            rdfs:comment "A constraint governing the use of one or more Services." .

uaf:ServiceContract rdf:type owl:Class ;
            uaf:xmiID "_19_0_2_3ed017a_1579800161228_967314_34230" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:Rule ;
            rdfs:label "ServiceContract" ;
            rdfs:comment "A constraint governing the use of one or more Services." .

uaf:ServiceMessage rdf:type owl:Class ;
            uaf:xmiID "3393b90e-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Sequences" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ServiceMessage" ;
            rdfs:comment "Message for use in a services interaction scenario which carries any of the subtypes of ServiceExchange." .

uaf:ServiceFunction rdf:type owl:Class ;
            uaf:xmiID "3591f990-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:Activity ;
            rdfs:label "ServiceFunction" ;
            rdfs:comment "An Activity that describes the abstract behavior of Services, regardless of the actual implementation." .

uaf:ServiceFunctionAction rdf:type owl:Class ;
            uaf:xmiID "2fc1c8f5-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ServiceFunctionAction" ;
            rdfs:comment "A call of a ServiceFunction in the context of another ServiceFunction." .

uaf:ServiceControlFlow rdf:type owl:Class ;
            uaf:xmiID "_19_0_2_3ed017a_1582887418011_222734_74829" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:ServiceFunctionEdge ;
            rdfs:label "ServiceControlFlow" ;
            rdfs:comment "An ActivityEdge that shows the flow of control between ServiceFunctionActions." .

uaf:ServiceObjectFlow rdf:type owl:Class ;
            uaf:xmiID "_19_0_2_3ed017a_1582887429830_147579_74855" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:ServiceFunctionEdge ;
            rdfs:label "ServiceObjectFlow" ;
            rdfs:comment "An ActivityEdge that shows the flow of Resources (objects/information) between ServiceFunctionActions." .

uaf:ServiceFunctionEdge rdf:type owl:Class ;
            uaf:xmiID "_19_0_2_3ed017a_1582887204841_231218_74767" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ServiceFunctionEdge" ;
            rdfs:comment "Abstract grouping for ServiceControlFlow and ServiceObjectFlow." .

uaf:ServiceStateDescription rdf:type owl:Class ;
            uaf:xmiID "33ac2253-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "States" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ServiceStateDescription" ;
            rdfs:comment "A state machine describing the behavior of a Service, depicting how the Service responds to various events and the actions." .

uaf:Supports rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_7d40257_1418147540872_779197_55320" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Traceability" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Supports" ;
            rdfs:comment "A abstraction relationship that asserts that a service in someway contributes or assists in the execution of an OperationalActivity." .

uaf:GovernedBy rdf:type owl:Class ;
            uaf:xmiID "_19_0_2_3ed017a_1595234389984_112358_34208" ;
            uaf:gridAspect "Services" ;
            uaf:gridViewpoint "Traceability" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "GovernedBy" ;
            rdfs:comment "An abstraction relationship that exists between the ServiceContract and the Service that it governs." .

uaf:ResourceRole rdf:type owl:Class ;
            uaf:xmiID "31e3bea6-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:LocationHolder ;
            rdfs:subClassOf uaf:SubjectOfResourceConstraint ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:subClassOf uaf:AssetRole ;
            rdfs:subClassOf uaf:OpposableElement ;
            rdfs:label "ResourceRole" ;
            rdfs:comment "Usage of a ResourcePerformer in the context of another ResourcePerformer. Creates a whole-part relationship." .

uaf:ResourcePort rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_8f40297_1425564112144_294726_32222" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:subClassOf uaf:ProtocolImplementation ;
            rdfs:label "ResourcePort" ;
            rdfs:comment "An interaction point for a ResourcePerformer through which it can interact with the outside environment and which is defined by a ResourceInterface." .

uaf:ResourceMethod rdf:type owl:Class ;
            uaf:xmiID "3226466d-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ResourceMethod" ;
            rdfs:comment "A behavioral feature of a ResourcePerformer whose behavior is specified in a Function." .

uaf:ResourceParameter rdf:type owl:Class ;
            uaf:xmiID "316e4057-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ResourceParameter" ;
            rdfs:comment "An element that represents inputs and outputs of a Function. It is typed by a ResourceInteractionItem." .

uaf:CapabilityConfiguration rdf:type owl:Class ;
            uaf:xmiID "3448d7da-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ResourceArchitecture ;
            rdfs:label "CapabilityConfiguration" ;
            rdfs:comment "A composite structure representing the physical and human resources (and their interactions) in an enterprise, assembled to meet a capability." .

uaf:NaturalResource rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1416212405660_732910_30951" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:PhysicalResource ;
            rdfs:label "NaturalResource" ;
            rdfs:comment "Type of physical resource that occurs in nature such as oil, water, gas or coal." .

uaf:PhysicalResource rdf:type owl:Class ;
            uaf:xmiID "31cd7766-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ResourcePerformer ;
            rdfs:label "PhysicalResource" ;
            rdfs:comment "An abstract grouping that defines physical resources (i.e. OrganizationalResource, ResourceArtifact and NaturalResource)." .

uaf:ResourceArchitecture rdf:type owl:Class ;
            uaf:xmiID "320d66db-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ResourcePerformer ;
            rdfs:subClassOf uaf:Architecture ;
            rdfs:label "ResourceArchitecture" ;
            rdfs:comment "An element used to denote a model of the Architecture, described from the ResourcePerformer perspective." .

uaf:ResourceArtifact rdf:type owl:Class ;
            uaf:xmiID "2f222d5a-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:PhysicalResource ;
            rdfs:label "ResourceArtifact" ;
            rdfs:comment "A type of man-made object that contains no human beings (i.e. satellite, radio, petrol, gasoline, etc.)." .

uaf:Software rdf:type owl:Class ;
            uaf:xmiID "2fb238c0-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ResourceArtifact ;
            rdfs:label "Software" ;
            rdfs:comment "A sub-type of ResourceArtifact that specifies an executable computer program." .

uaf:ResourcePerformer rdf:type owl:Class ;
            uaf:xmiID "35b7aa1e-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ResourceAsset ;
            rdfs:subClassOf uaf:ResourceExchangeItem ;
            rdfs:subClassOf uaf:SubjectOfResourceConstraint ;
            rdfs:subClassOf uaf:VersionedElement ;
            rdfs:subClassOf uaf:CapableElement ;
            rdfs:subClassOf uaf:SubjectOfForecast ;
            rdfs:subClassOf uaf:OperationalExchangeItem ;
            rdfs:subClassOf uaf:Desirer ;
            rdfs:subClassOf uaf:ServiceExchangeItem ;
            rdfs:subClassOf uaf:StrategicExchangeItem ;
            rdfs:subClassOf uaf:OpposableElement ;
            rdfs:label "ResourcePerformer" ;
            rdfs:comment "An abstract grouping of elements that can perform Functions." .

uaf:System rdf:type owl:Class ;
            uaf:xmiID "_18_2_8f40297_1449787854207_41245_35091" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ResourceArchitecture ;
            rdfs:label "System" ;
            rdfs:comment "An integrated set of elements, subsystems, or assemblies that accomplish a defined objective. These elements include products (hardware, software, firmware), processes, people, information, techniques, facilities, services, and other support elements (INCOSE SE Handbook V4, 2015)." .

uaf:ResourceService rdf:type owl:Class ;
            uaf:xmiID "_19_0_2_3ed017a_1596442467867_824320_34263" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ResourcePerformer ;
            rdfs:label "ResourceService" ;
            rdfs:comment "A services that a ResourcePerformer provides to support higher level Services or OperationalActivities. Employee provisioning, backup and recovery, storage, self-service help desk are examples of ResourceServices." .

uaf:ResourceExchange rdf:type owl:Class ;
            uaf:xmiID "33ab8609-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:Exchange ;
            rdfs:label "ResourceExchange" ;
            rdfs:comment "Asserts that a flow can exist between ResourcePerformers (i.e. flows of data, people, materiel, or energy)." .

uaf:ResourceInterface rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_8f40297_1425564395032_517246_32269" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "ResourceInterface" ;
            rdfs:comment "A declaration that specifies a contract between the ResourcePerformers it is related to and any other ResourcePerformers it can interact with. It is also intended to be an implementation of a specification of an Interface in the Business and/or Service layer." .

uaf:ResourceConnector rdf:type owl:Class ;
            uaf:xmiID "331c8cae-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:ProtocolImplementation ;
            rdfs:subClassOf uaf:AssetRole ;
            rdfs:label "ResourceConnector" ;
            rdfs:comment "A channel for exchange between two ResourceRoles." .

uaf:ResourceExchangeItem rdf:type owl:Class ;
            uaf:xmiID "3510465c-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:Resource ;
            rdfs:label "ResourceExchangeItem" ;
            rdfs:comment "An abstract grouping for elements that defines the types of elements that can be exchanged between ResourcePerformers and conveyed by a ResourceExchange." .

uaf:ResourceSignal rdf:type owl:Class ;
            uaf:xmiID "_18_4_1_8f40297_1481158927199_738788_35876" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:ResourceExchangeItem ;
            rdfs:label "ResourceSignal" ;
            rdfs:comment "A ResourceSignal is a specification of a kind of communication between resources (ResourcePerformers) in which a reaction is asynchronously triggered in the receiver without a reply." .

uaf:ResourceSignalProperty rdf:type owl:Class ;
            uaf:xmiID "_18_4_1_8f40297_1481159070653_506668_36010" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ResourceSignalProperty" ;
            rdfs:comment "A property of an ResourceSignal typed by ResourceExchangeItem. It enables ResourceExchangeItem e.g. ResourceInformation to be passed as arguments of the ResourceSignal." .

uaf:ResourceServiceInterface rdf:type owl:Class ;
            uaf:xmiID "_19_0_2_3ed017a_1596444090640_892771_37631" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:ResourceInterface ;
            rdfs:label "ResourceServiceInterface" ;
            rdfs:comment "A contract that defines the ResourceMethods and ResourceSignal receptions that the ResourceServices realize." .

uaf:ResourceConstraint rdf:type owl:Class ;
            uaf:xmiID "348a4d4a-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:Rule ;
            rdfs:label "ResourceConstraint" ;
            rdfs:comment "A rule governing the structural or functional aspects of an implementation." .

uaf:SubjectOfResourceConstraint rdf:type owl:Class ;
            uaf:xmiID "31112c37-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "SubjectOfResourceConstraint" ;
            rdfs:comment "An abstract grouping of elements that can be the subject of a ResourceConstraint. Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:ResourceInformation rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1417010839901_224050_44436" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Information" ;
            rdfs:subClassOf uaf:ResourceExchangeItem ;
            rdfs:subClassOf uaf:SubjectOfResourceConstraint ;
            rdfs:subClassOf uaf:ResourceAsset ;
            rdfs:label "ResourceInformation" ;
            rdfs:comment "A formalized representation of information that is managed by or exchanged between systems." .

uaf:ResourceMessage rdf:type owl:Class ;
            uaf:xmiID "351f1340-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Sequences" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ResourceMessage" ;
            rdfs:comment "Message for use in a Resource Event-Trace which carries any of the subtypes of ResourceExchange." .

uaf:Function rdf:type owl:Class ;
            uaf:xmiID "323e88b6-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:Activity ;
            rdfs:subClassOf uaf:SubjectOfResourceConstraint ;
            rdfs:label "Function" ;
            rdfs:comment "An Activity which is specified in the context to the ResourcePerformer (human or machine) that IsCapableToPerform it." .

uaf:FunctionAction rdf:type owl:Class ;
            uaf:xmiID "30f7b167-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "FunctionAction" ;
            rdfs:comment "A call of a Function indicating that the  Function is performed by a ResourceRole in a specific context." .

uaf:FunctionControlFlow rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_7d40257_1418169917478_819184_70675" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:FunctionEdge ;
            rdfs:label "FunctionControlFlow" ;
            rdfs:comment "An ActivityEdge that shows the flow of control between FunctionActions." .

uaf:FunctionEdge rdf:type owl:Class ;
            uaf:xmiID "30f42eca-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "FunctionEdge" ;
            rdfs:comment "Abstract grouping for FunctionControlFlow and FunctionObjectFlow." .

uaf:FunctionObjectFlow rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_7d40257_1418169887497_613090_70649" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:FunctionEdge ;
            rdfs:label "FunctionObjectFlow" ;
            rdfs:comment "An ActivityEdge that shows the flow of Resources (objects/data) between FunctionActions." .

uaf:MissionEngineeringThread rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1716909010072_481896_5923" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:Function ;
            rdfs:label "MissionEngineeringThread" ;
            rdfs:comment "A sequence of end-to-end mission-related functions, actions, and events presented as a series of steps that implements a mission thread." .

uaf:VersionedElement rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_7d40257_1418150923359_895933_56175" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Roadmap" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "VersionedElement" ;
            rdfs:comment "An abstract grouping of ResourcePerformer and Service that allows VersionOfConfiguration to be related to ActualProjectMilestones. Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:Forecast rdf:type owl:Class ;
            uaf:xmiID "3079f537-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Roadmap" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Forecast" ;
            rdfs:comment "A dependency relationship that specifies a transition from one Resource Performer, Standard, Competence to another future one. It is related to an ActualStrategicPhase to give it a temporal context." .

uaf:SubjectOfForecast rdf:type owl:Class ;
            uaf:xmiID "33b9426d-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Roadmap" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "SubjectOfForecast" ;
            rdfs:comment "An abstract grouping of  elements that can be the subject of a Forecast. Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:Technology rdf:type owl:Class ;
            uaf:xmiID "35aad927-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Roadmap" ;
            rdfs:subClassOf uaf:ResourceArtifact ;
            rdfs:label "Technology" ;
            rdfs:comment "A sub type of ResourceArtifact that indicates a technology domain, i.e. nuclear, mechanical, electronic, mobile telephony etc." .

uaf:VersionOfConfiguration rdf:type owl:Class ;
            uaf:xmiID "34a353d3-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Roadmap" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "VersionOfConfiguration" ;
            rdfs:comment "A property of a WholeLifeConfiguration, used in version control of a VersionedElement. It asserts that a VersionedElement is a version of a WholeLifeConfiguration." .

uaf:VersionSuccession rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1417162530056_546066_31742" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Roadmap" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "VersionSuccession" ;
            rdfs:comment "A dependency relationship between two  VersionOfConfigurations that denotes that one VersionOfConfiguration follows from another." .

uaf:WholeLifeConfiguration rdf:type owl:Class ;
            uaf:xmiID "2fb8a1b8-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Roadmap" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "WholeLifeConfiguration" ;
            rdfs:comment "A set of VersionedElements, e.g. Services for a service provider or ResourcePerformers deployed for implementation." .

uaf:ResourceStateDescription rdf:type owl:Class ;
            uaf:xmiID "34f89f5c-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "States" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ResourceStateDescription" ;
            rdfs:comment "A state machine describing the behavior of a ResourcePerformer, depicting how the ResourcePerformer responds to various events and the actions." .

uaf:ProtocolImplementation rdf:type owl:Class ;
            uaf:xmiID "_18_1_8f40297_1433423294413_498087_33992" ;
            uaf:gridAspect "Resources" ;
            uaf:gridViewpoint "Traceability" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "ProtocolImplementation" ;
            rdfs:comment "An abstract grouping of architectural elements that can implement Protocols. Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:StructuralPart rdf:type owl:Class ;
            uaf:xmiID "2f4398bc-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "StructuralPart" ;
            rdfs:comment "Usage of a StrategicPhase in the context of another StrategicPhase. It asserts that one StrategicPhase is a spatial part of another. Creates a whole-part relationship that represents the structure of the StrategicPhase." .

uaf:CapabilityRole rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1416906522687_239696_33050" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:subClassOf uaf:Desirer ;
            rdfs:label "CapabilityRole" ;
            rdfs:comment "Property of a Capability typed by another Capability, enabling whole-part relationships and structures." .

uaf:TemporalPart rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1416927365955_753605_38151" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "TemporalPart" ;
            rdfs:comment "Usage of a StrategicPhase in the context of another StrategicPhase. It asserts that one StrategicPhase is a spatial part of another. Creates a whole-part relationship that represents the temporal structure of the StrategicPhase." .

uaf:EnterpriseGoal rdf:type owl:Class ;
            uaf:xmiID "3253e5a2-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:subClassOf uaf:PhaseableElement ;
            rdfs:subClassOf uaf:AffectableElement ;
            rdfs:label "EnterpriseGoal" ;
            rdfs:comment "A statement about a state or condition of the enterprise to be brought about or sustained through appropriate Means. An EnterpriseGoal amplifies an EnterpriseVision that is, it indicates what must be satisfied on a continuing basis to effectively attain the EnterpriseVision. http://www.omg.org/spec/BMM/1.3/" .

uaf:StrategicPhase rdf:type owl:Class ;
            uaf:xmiID "30c26fb1-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "StrategicPhase" ;
            rdfs:comment "A type of a current or future phase of the enterprise, mission, ValueStream, or EnduringTask." .

uaf:EnterpriseVision rdf:type owl:Class ;
            uaf:xmiID "31b6e1f0-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:subClassOf uaf:PhaseableElement ;
            rdfs:label "EnterpriseVision" ;
            rdfs:comment "A Vision describes the future state of the enterprise, without regard to how it is to be achieved. http://www.omg.org/spec/BMM/1.3/" .

uaf:VisionStatement rdf:type owl:Class ;
            uaf:xmiID "34d70dd4-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "VisionStatement" ;
            rdfs:comment "A type of comment that describes the future state of the enterprise, without regard to how it is to be achieved. http://www.omg.org/spec/BMM/1.3/" .

uaf:WholeLifeEnterprise rdf:type owl:Class ;
            uaf:xmiID "30376e59-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ActualEnterprisePhase ;
            rdfs:label "WholeLifeEnterprise" ;
            rdfs:comment "A WholeLifeEnterprise is a purposeful endeavor of any size involving people, organizations and supporting systems. It is made up of TemporalParts and StructuralParts." .

uaf:EnterpriseObjective rdf:type owl:Class ;
            uaf:xmiID "_19_0_2_3ed017a_1582656021797_120123_70505" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:EnterpriseGoal ;
            rdfs:label "EnterpriseObjective" ;
            rdfs:comment "A statement of an attainable, time-targeted, and measurable target that the enterprise seeks to meet in order to achieve its Goals. http://www.omg.org/spec/BMM/1.3/" .

uaf:StrategicAsset rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1612525601921_407887_799" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:Asset ;
            rdfs:label "StrategicAsset" ;
            rdfs:comment "An abstract element that indicates the types of strategic elements that can be affected by Risk." .

uaf:ValueItem rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1607507715753_862833_1324" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:MeasurementSet ;
            rdfs:subClassOf uaf:StrategicAsset ;
            rdfs:label "ValueItem" ;
            rdfs:comment "An ideal, custom, or institution that an enterprise promotes or agrees with. It may be positive or negative, depending on point of view." .

uaf:OwnsValue rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1607508982773_936512_1533" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "OwnsValue" ;
            rdfs:comment "An abstraction relationship denoting that an ActualOrganizationalResource owns a ValueItem" .

uaf:PhaseableElement rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1616324648263_416149_79" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "PhaseableElement" ;
            rdfs:comment "An abstract element that indicates the types of elements that can be assigned to a specific ActualStrategicPhase." .

uaf:Mission rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1715341558058_881151_16" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:StrategicPhase ;
            rdfs:label "Mission" ;
            rdfs:comment "The task, together with the purpose, that clearly indicates the action to be taken and the reasoning behind the mission. (JP 1-02)" .

uaf:StrategicExchangeItem rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1612520631888_63181_278" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:Resource ;
            rdfs:label "StrategicExchangeItem" ;
            rdfs:comment "An abstract grouping for elements that defines the types of elements that can be exchanged between ActualStrategicPhases and conveyed by a StrategicExchange." .

uaf:StrategicExchange rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1612521345743_608330_534" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:Exchange ;
            rdfs:label "StrategicExchange" ;
            rdfs:comment "Asserts that a flow can exist between ActualStrategicPhases (i.e. flows of information, people, materiel, or energy)." .

uaf:StrategicConstraint rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1619622784114_804700_4296" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:Rule ;
            rdfs:label "StrategicConstraint" ;
            rdfs:comment "A Rule governing a Capability." .

uaf:SubjectOfStrategicConstraint rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1619622855894_777847_4326" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "SubjectOfStrategicConstraint" ;
            rdfs:comment "An abstract grouping of elements that can be the subject of a StrategicConstraint." .

uaf:StrategicInformation rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1612521378524_953366_565" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Information" ;
            rdfs:subClassOf uaf:StrategicExchangeItem ;
            rdfs:subClassOf uaf:StrategicAsset ;
            rdfs:label "StrategicInformation" ;
            rdfs:comment "Knowledge communicated or received concerning a particular fact or circumstance that is strategic in nature that is important or essential in relation to a plan of action" .

uaf:MapsToGoal rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1613065021260_728049_3629" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Information" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "MapsToGoal" ;
            rdfs:comment "A dependency relationship denoting that some StrategicInformation contributes to achieving an EnterpriseGoal or Objective." .

uaf:ActualEnduringTask rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1416302917837_288772_33204" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:ActualStrategicPhase ;
            rdfs:label "ActualEnduringTask" ;
            rdfs:comment "An actual undertaking recognized by an enterprise as being essential to achieving its goals - i.e. a strategic specification of what the enterprise does." .

uaf:ActualStrategicPhase rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1612520992180_668614_450" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:Achiever ;
            rdfs:subClassOf uaf:ActualPropertySet ;
            rdfs:label "ActualStrategicPhase" ;
            rdfs:comment "A phase of an actual enterprise, mission, ValueStream or EnduringTask endeavor." .

uaf:Creates rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1612526362699_126217_1089" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Creates" ;
            rdfs:comment "A dependency relationship denoting that an ActualStrategicPhase brings into existence a StrategicAsset." .

uaf:ValueStream rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1610712196090_518139_342" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:ActualStrategicPhase ;
            rdfs:label "ValueStream" ;
            rdfs:comment "An end-to-end collection of activities that create a result for a customer, who may be the ultimate customer or an internal end-user of the value stream. Value stream nested within another value stream may represent Value Stream Stage - a distinct, identifiable phase or step within a value stream [The Business Architecture Metamodel Guide, 2020]." .

uaf:ActualMission rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1610712180609_829729_313" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:ActualStrategicPhase ;
            rdfs:label "ActualMission" ;
            rdfs:comment "A particular mission to accomplish assigned mission objectives" .

uaf:ActualEnterprisePhase rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1415802551499_644810_37502" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:ActualStrategicPhase ;
            rdfs:label "ActualEnterprisePhase" ;
            rdfs:comment "A time period within which a set of Capabilities are deployed." .

uaf:ActualMissionPhase rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1715342853548_981209_412" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:ActualMission ;
            rdfs:label "ActualMissionPhase" ;
            rdfs:comment "A particular phase in the accomplishment of an overall actual mission" .

uaf:Defines rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1716381727517_127237_1437" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Defines" ;
            rdfs:comment "A tuple that links the StrategicPhase and the Activity that implements it" .

uaf:Achieves rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_7d40257_1418161485070_218792_61728" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "States" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Achieves" ;
            rdfs:comment "A dependency relationship that exists between an ActualState (e.g., observed/measured during testing) of an element that attempts to achieve a desired effect and an Achiever." .

uaf:Achiever rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_7d40257_1418161447125_395841_61699" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "States" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "Achiever" ;
            rdfs:comment "An ActualResource, ActualProject or ActualStrategicPhase that can deliver a desired effect." .

uaf:Desires rdf:type owl:Class ;
            uaf:xmiID "31a8b156-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "States" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Desires" ;
            rdfs:comment "A dependency relationship relating the Desirer (a Capability or OrganizationalResource) to an ActualState." .

uaf:Desirer rdf:type owl:Class ;
            uaf:xmiID "31433957-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "States" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "Desirer" ;
            rdfs:comment "Abstract element used to group architecture elements that might desire a particular effect. Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:ActualEffect rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1611322987834_367814_33" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "States" ;
            rdfs:subClassOf uaf:ActualPropertySet ;
            rdfs:label "ActualEffect" ;
            rdfs:comment "A real world phenomenon that follows and is caused by some previous phenomenon." .

uaf:ActualOutcome rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1611323483312_965879_127" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "States" ;
            rdfs:subClassOf uaf:ActualEffect ;
            rdfs:label "ActualOutcome" ;
            rdfs:comment "Something that happens or is produced as the final consequence or product and is related to one of the goals for the business or enterprise. Outcome is a special kind of effect, one that is usually at the end of a chain of effects, i.e. an \"end effect\"." .

uaf:Effect rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1607698277180_900472_1914" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "States" ;
            rdfs:subClassOf uaf:MotivationalElement ;
            rdfs:label "Effect" ;
            rdfs:comment "A kind of phenomenon that follows and is caused by some previous phenomenon that could lead to downstream effects or to one or more desired outcomes" .

uaf:Exhibits rdf:type owl:Class ;
            uaf:xmiID "316f78e8-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Traceability" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Exhibits" ;
            rdfs:comment "An abstraction relationship that exists between a CapableElement and a Capability that it meets under specific environmental conditions." .

uaf:MapsToCapability rdf:type owl:Class ;
            uaf:xmiID "2f1c3a98-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Traceability" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "MapsToCapability" ;
            rdfs:comment "An Abstraction relationship denoting that an Activity contributes to providing a Capability." .

uaf:OrganizationInPhase rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1416901553886_807009_31315" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Traceability" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "OrganizationInPhase" ;
            rdfs:comment "An abstraction relationship relating an ActualOrganization to an ActualStrategicPhase to denote that the ActualOrganization plays a role or is a stakeholder in an ActualStrategicPhase." .

uaf:EvokedBy rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1619511688115_19729_983" ;
            uaf:gridAspect "Strategic" ;
            uaf:gridViewpoint "Traceability" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "EvokedBy" ;
            rdfs:comment "A dependency relationship denoting that a Risk is drawn out by an Opportunity." .

uaf:PresentedBy rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1605881021766_737569_565" ;
            uaf:gridAspect "Strategic" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "PresentedBy" ;
            rdfs:comment "A dependency relationship denoting that a Challenge must be overcome for addressing a Driver." .

uaf:MotivationalElement rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1605879737449_974479_398" ;
            uaf:gridAspect "Strategic" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:subClassOf uaf:PhaseableElement ;
            rdfs:label "MotivationalElement" ;
            rdfs:comment "An abstract kind of element in the model that provides the reason or reasons one has for acting or behaving in a particular way" .

uaf:Challenge rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1605878030084_650404_15" ;
            uaf:gridAspect "Strategic" ;
            rdfs:subClassOf uaf:MotivationalElement ;
            rdfs:label "Challenge" ;
            rdfs:comment "An existing or potential difficulty, circumstance, or obstacle which will require effort and determination from an enterprise to overcome in achieving its goals." .

uaf:Driver rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1605878090475_155078_145" ;
            uaf:gridAspect "Strategic" ;
            rdfs:subClassOf uaf:MotivationalElement ;
            rdfs:label "Driver" ;
            rdfs:comment "A factor which will have a significant impact on the activities, and goals of an enterprise" .

uaf:Opportunity rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1605878082735_443154_119" ;
            uaf:gridAspect "Strategic" ;
            rdfs:subClassOf uaf:MotivationalElement ;
            rdfs:subClassOf uaf:AffectableElement ;
            rdfs:label "Opportunity" ;
            rdfs:comment "An existing or potential favorable circumstance or combination of circumstances which can be advantageous for addressing enterprise Challenges." .

uaf:Enables rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1605882019667_562511_888" ;
            uaf:gridAspect "Strategic" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Enables" ;
            rdfs:comment "A dependency relationship denoting that an Opportunity provides the means for achieving an EnterpriseGoal or Objective." .

uaf:ImpactedBy rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1605881009797_424662_539" ;
            uaf:gridAspect "Strategic" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ImpactedBy" ;
            rdfs:comment "A dependency relationship denoting that a Capability is affected by an Opportunity." .

uaf:MotivatedBy rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1615559868534_102552_127" ;
            uaf:gridAspect "Strategic" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "MotivatedBy" ;
            rdfs:comment "A dependency relationship denoting the reason or reasons one has for acting or behaving in a particular way" .

uaf:ActualResponsibility rdf:type owl:Class ;
            uaf:xmiID "_18_1_8f40297_1434376235197_88897_40517" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ActualOrganizationalResource ;
            rdfs:label "ActualResponsibility" ;
            rdfs:comment "The duty required of a Person or Organization." .

uaf:ActualPost rdf:type owl:Class ;
            uaf:xmiID "2f9428fd-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ActualResponsibleResource ;
            rdfs:label "ActualPost" ;
            rdfs:comment "An actual, specific post, an instance of a Post \"type\" - e.g., \"President of the United States of America.\" where the Post would be president." .

uaf:FieldedCapability rdf:type owl:Class ;
            uaf:xmiID "357ceac3-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ActualResource ;
            rdfs:label "FieldedCapability" ;
            rdfs:comment "An actual, fully-realized capability. A FieldedCapability is typed by a CapabilityConfiguration." .

uaf:ActualOrganizationalResource rdf:type owl:Class ;
            uaf:xmiID "31e1c2ba-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:Stakeholder ;
            rdfs:subClassOf uaf:ActualResource ;
            rdfs:label "ActualOrganizationalResource" ;
            rdfs:comment "Abstract element for an ActualOrganization, ActualPerson or ActualPost." .

uaf:ActualOrganization rdf:type owl:Class ;
            uaf:xmiID "3438f98e-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ActualResponsibleResource ;
            rdfs:label "ActualOrganization" ;
            rdfs:comment "An actual formal or informal organizational unit, e.g. \"Driving and Vehicle Licensing Agency\", \"UAF team Alpha\"." .

uaf:ActualResource rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1414668604288_585134_36188" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ActualPropertySet ;
            rdfs:subClassOf uaf:SubjectOfResourceConstraint ;
            rdfs:subClassOf uaf:Achiever ;
            rdfs:subClassOf uaf:CapableElement ;
            rdfs:label "ActualResource" ;
            rdfs:comment "An instance of a ResourcePerformer in the real world." .

uaf:ActualPerson rdf:type owl:Class ;
            uaf:xmiID "33ef6ce5-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ActualResponsibleResource ;
            rdfs:label "ActualPerson" ;
            rdfs:comment "An individual human being." .

uaf:ActualResponsibleResource rdf:type owl:Class ;
            uaf:xmiID "_18_1_8f40297_1434376309107_61992_40544" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ActualOrganizationalResource ;
            rdfs:label "ActualResponsibleResource" ;
            rdfs:comment "An abstract grouping of responsible OrganizationalResources." .

uaf:ActualResourceRole rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1416382985202_771145_32313" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "ActualResourceRole" ;
            rdfs:comment "An instance of a ResourcePerformer." .

uaf:ActualOrganizationRole rdf:type owl:Class ;
            uaf:xmiID "32281a47-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:ActualResourceRole ;
            rdfs:label "ActualOrganizationRole" ;
            rdfs:comment "An ActualOrganizationalResource that is applied to a ResourceRole." .

uaf:ActualResourceRelationship rdf:type owl:Class ;
            uaf:xmiID "312b4454-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "ActualResourceRelationship" ;
            rdfs:comment "An abstract element that details the ActualOrganizationalResources that are able to carry out an ActualResponsibility." .

uaf:FillsPost rdf:type owl:Class ;
            uaf:xmiID "31f63515-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "FillsPost" ;
            rdfs:comment "A dependency relationship that asserts that an ActualPerson fills an ActualPost." .

uaf:ActualService rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1415879801705_136343_35559" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:ActualMeasurementSet ;
            rdfs:subClassOf uaf:CapableElement ;
            rdfs:label "ActualService" ;
            rdfs:comment "An instance of a Service." .

uaf:ProvidedServiceLevel rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1415954361982_271147_31439" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:ActualService ;
            rdfs:label "ProvidedServiceLevel" ;
            rdfs:comment "A sub type of ActualService that details a specific service level delivered by the provider." .

uaf:RequiredServiceLevel rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1415954386156_641774_31450" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:ActualService ;
            rdfs:label "RequiredServiceLevel" ;
            rdfs:comment "A sub type of ActualService that details a specific service level required of the provider." .

uaf:ProvidesCompetence rdf:type owl:Class ;
            uaf:xmiID "358e76ef-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ProvidesCompetence" ;
            rdfs:comment "A dependency relationship that asserts that an ActualOrganizationalResource provides a specific set of Competencies." .

uaf:OwnsProcess rdf:type owl:Class ;
            uaf:xmiID "3513f011-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridViewpoint "Traceability" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "OwnsProcess" ;
            rdfs:comment "A dependency relationship denoting that an ActualOrganizationResource owns an OperationalActivity." .

uaf:Competence rdf:type owl:Class ;
            uaf:xmiID "339a210b-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Personnel" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:SubjectOfForecast ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "Competence" ;
            rdfs:comment "A specific set of abilities defined by knowledge, skills and aptitude." .

uaf:CompetenceForRole rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_8f40297_1425652883223_136047_44527" ;
            uaf:gridAspect "Personnel" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "CompetenceForRole" ;
            rdfs:comment "An abstraction relationship used to associate an organizational role with a specific set of required competencies." .

uaf:RequiresCompetence rdf:type owl:Class ;
            uaf:xmiID "3598fed5-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Personnel" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "RequiresCompetence" ;
            rdfs:comment "An abstraction relationship that asserts that an ActualOrganizationalResource is required to have a specific set of Competencies." .

uaf:CompetenceToConduct rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1416297797213_93734_34674" ;
            uaf:gridAspect "Personnel" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "CompetenceToConduct" ;
            rdfs:comment "An abstraction relationship used to associate a Function with a specific set of Competencies needed to conduct the Function." .

uaf:Organization rdf:type owl:Class ;
            uaf:xmiID "309322d0-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Personnel" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:OrganizationalResource ;
            rdfs:label "Organization" ;
            rdfs:comment "A group of OrganizationalResources (Persons, Posts, Organizations and Responsibilities) associated for a particular purpose." .

uaf:OrganizationalResource rdf:type owl:Class ;
            uaf:xmiID "31926a1c-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Personnel" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:PhysicalResource ;
            rdfs:subClassOf uaf:Stakeholder ;
            rdfs:label "OrganizationalResource" ;
            rdfs:comment "An abstract element grouping for Organization, Person, Post and Responsibility." .

uaf:Person rdf:type owl:Class ;
            uaf:xmiID "34b3a768-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Personnel" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:OrganizationalResource ;
            rdfs:label "Person" ;
            rdfs:comment "A type of a human being used to define the characteristics that need to be described for ActualPersons (e.g. properties such as address, telephone number, nationality, etc)." .

uaf:Post rdf:type owl:Class ;
            uaf:xmiID "3272b7e5-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Personnel" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:OrganizationalResource ;
            rdfs:label "Post" ;
            rdfs:comment "A type of job title or position that a person can fill (e.g. Lawyer, Solution Architect, Machine Operator or Chief Executive Officer)." .

uaf:Responsibility rdf:type owl:Class ;
            uaf:xmiID "_18_1_8f40297_1434615565902_257194_46692" ;
            uaf:gridAspect "Personnel" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:OrganizationalResource ;
            rdfs:label "Responsibility" ;
            rdfs:comment "The type of duty required of a Person or Organization." .

uaf:Control rdf:type owl:Class ;
            uaf:xmiID "33962932-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Personnel" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:ResourceExchange ;
            rdfs:label "Control" ;
            rdfs:comment "A type of ResourceExchange that asserts that one PhysicalResource controls another PhysicalResource (i.e.  the driver of a vehicle controlling the vehicle speed or direction)." .

uaf:Command rdf:type owl:Class ;
            uaf:xmiID "334e23bc-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Personnel" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:ResourceExchange ;
            rdfs:label "Command" ;
            rdfs:comment "A type of ResourceExchange that asserts that one OrganizationalResource commands another." .

uaf:ResponsibleFor rdf:type owl:Class ;
            uaf:xmiID "313ef36a-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Personnel" ;
            uaf:gridViewpoint "Traceability" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ResponsibleFor" ;
            rdfs:comment "An abstraction relationship between an ActualResponsibleResource and an ActualResponsibility or ActualProject. It defines the duties that the ActualResponsibleResource is ResponsibleFor." .

uaf:Asset rdf:type owl:Class ;
            uaf:xmiID "3057a048-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ConceptItem ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:subClassOf uaf:SubjectOfSecurityConstraint ;
            rdfs:subClassOf uaf:AffectableElement ;
            rdfs:label "Asset" ;
            rdfs:comment "An abstract element that indicates the types of elements that can be affected by Risk. Asset as applied to Security views is an abstract element that indicates the types of elements that can be considered as a subject for security analysis." .

uaf:OperationalMitigation rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1416572620544_980456_34538" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:OperationalArchitecture ;
            rdfs:label "OperationalMitigation" ;
            rdfs:comment "A set of OperationalPerformers intended to address against specific operational risks." .

uaf:ResourceMitigation rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1417253134765_859482_33435" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ResourceArchitecture ;
            rdfs:label "ResourceMitigation" ;
            rdfs:comment "A set of ResourcePerformers intended to address against specific risks." .

uaf:SecurityEnclave rdf:type owl:Class ;
            uaf:xmiID "_18_1_8f40297_1442928617990_797462_47126" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:ResourceArchitecture ;
            rdfs:label "SecurityEnclave" ;
            rdfs:comment "Collection of information systems connected by one or more internal networks under the control of a single authority and security policy. The systems may be structured by physical proximity or by function, independent of location." .

uaf:OperationalAsset rdf:type owl:Class ;
            uaf:xmiID "_18_4_1_8f40297_1529342445853_264721_39789" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:Asset ;
            rdfs:label "OperationalAsset" ;
            rdfs:comment "An abstract element used to group the elements of OperationalAgent and OperationalInformation allowing them to own OperationalInformationRoles." .

uaf:ResourceAsset rdf:type owl:Class ;
            uaf:xmiID "_18_4_1_8f40297_1529342477249_886637_39816" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:Asset ;
            rdfs:label "ResourceAsset" ;
            rdfs:comment "An abstract element used to group the elements of ResourcePerformer and ResourceInformation allowing them to own ResourceInformationRoles" .

uaf:SubjectOfSecurityConstraint rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1417421885234_739833_32794" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "SubjectOfSecurityConstraint" ;
            rdfs:comment "An abstract grouping of elements that can be the subject of a SecurityConstraint. Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:SecurityConstraint rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1417421461053_859391_32695" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:Rule ;
            rdfs:label "SecurityConstraint" ;
            rdfs:comment "A type of rule that captures a formal statement to define security laws, regulations, guidances, and policy." .

uaf:SecurityRisk rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1619120887767_780640_906" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Constraints" ;
            rdfs:subClassOf uaf:Risk ;
            rdfs:label "SecurityRisk" ;
            rdfs:comment "The level of impact on enterprise operations, assets, or individuals resulting from the operation of an information system given the potential impact of a threat and the likelihood of that threat occurring [NIST SP 800-65]." .

uaf:SecurityProcessAction rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1417445921130_262316_37992" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:OperationalActivityAction ;
            rdfs:subClassOf uaf:FunctionAction ;
            rdfs:label "SecurityProcessAction" ;
            rdfs:comment "A call of a SecurityProcess in the context of another SecurityProcess." .

uaf:SecurityProcess rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1417445871590_721317_37959" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:OperationalActivity ;
            rdfs:subClassOf uaf:Function ;
            rdfs:subClassOf uaf:SubjectOfSecurityConstraint ;
            rdfs:label "SecurityProcess" ;
            rdfs:comment "The security-related procedure that satisfies the security control requirement." .

uaf:OperationalInformationRole rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1417445400580_973556_37759" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:AssetRole ;
            rdfs:label "OperationalInformationRole" ;
            rdfs:comment "A usage of OperationalInformation that exists in the context of an OperationalAsset. It also allows the representation of the whole-part aggregation of OperationalInformation elements." .

uaf:AssetRole rdf:type owl:Class ;
            uaf:xmiID "_18_2_8f40297_1449697976348_904324_36585" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:subClassOf uaf:SubjectOfSecurityConstraint ;
            rdfs:label "AssetRole" ;
            rdfs:comment "An abstract element that indicates the types of elements that can be affected by Risk in the particular context. AssetRole as applied to Security views, is an abstract element that indicates the type of elements that can be considered as a subject for security analysis in the particular context. Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:ResourceInformationRole rdf:type owl:Class ;
            uaf:xmiID "_18_4_1_8f40297_1529343087074_873684_40379" ;
            uaf:gridAspect "Security" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:AssetRole ;
            rdfs:label "ResourceInformationRole" ;
            rdfs:comment "A usage of ResourceInformation that exists in the context of a ResourceAsset. It also allows the representation of the whole-part aggregation of ResourceInformation elements." .

uaf:Enhances rdf:type owl:Class ;
            uaf:xmiID "_18_1_8f40297_1442860264953_490078_45011" ;
            uaf:gridAspect "Security" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Enhances" ;
            rdfs:comment "A dependency relationship relating the EnhancedSecurityControl to a SecurityControl." .

uaf:ProtectsInContext rdf:type owl:Class ;
            uaf:xmiID "_18_1_8f40297_1442862698615_521675_45376" ;
            uaf:gridAspect "Security" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ProtectsInContext" ;
            rdfs:comment "A dependency relationship that relates a SecurityControlAction to a OperationalRole, or a ResourceRole. It indicates that SecurityControl is required to protect an Asset in a specific context or configuration." .

uaf:EnhancedSecurityControl rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1417504603752_222913_32136" ;
            uaf:gridAspect "Security" ;
            rdfs:subClassOf uaf:SecurityControl ;
            rdfs:label "EnhancedSecurityControl" ;
            rdfs:comment "Statement of security capability to: (i) build in additional but related, functionality to a basic control; and/or (ii)increase the strength of a basic control." .

uaf:Protects rdf:type owl:Class ;
            uaf:xmiID "_18_1_8f40297_1442862318209_456472_45195" ;
            uaf:gridAspect "Security" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Protects" ;
            rdfs:comment "A dependency that asserts that a SecurityControl is required to protect an Asset." .

uaf:SecurityControl rdf:type owl:Class ;
            uaf:xmiID "_18_4_1_8f40297_1490706124426_737185_36067" ;
            uaf:gridAspect "Security" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "SecurityControl" ;
            rdfs:comment "The management, operational, and technical control (i.e., safeguard or countermeasure) prescribed for an information system to protect the confidentiality, integrity, and availability of the system and its information [NIST SP 800-53]." .

uaf:SecurityControlFamily rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1417446101919_516426_38056" ;
            uaf:gridAspect "Security" ;
            rdfs:subClassOf uaf:SecurityControl ;
            rdfs:label "SecurityControlFamily" ;
            rdfs:comment "An element that organizes security controls into a family. Each Security Control Family contains security controls related to the general security topic of the family." .

uaf:Protocol rdf:type owl:Class ;
            uaf:xmiID "326794ca-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Standards" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:Standard ;
            rdfs:label "Protocol" ;
            rdfs:comment "A Standard for communication over a network. Protocols may be composite, represented as a ProtocolStack made up of ProtocolLayers." .

uaf:ProtocolStack rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1416987203590_353319_31493" ;
            uaf:gridAspect "Standards" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:Protocol ;
            rdfs:label "ProtocolStack" ;
            rdfs:comment "A sub-type of Protocol that contains the ProtocolLayers, defining a complete stack." .

uaf:Standard rdf:type owl:Class ;
            uaf:xmiID "2ff3d51f-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Standards" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:SubjectOfForecast ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "Standard" ;
            rdfs:comment "A ratified and peer-reviewed specification that is used to guide or constrain the architecture. A Standard may be applied to any element in the architecture." .

uaf:Doctrine rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1718781309353_72043_258" ;
            uaf:gridAspect "Standards" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:Standard ;
            rdfs:label "Doctrine" ;
            rdfs:comment "A formal expression of military knowledge and thought, accepted as being relevant at a given time, which covers the nature of conflict, the preparation of the military forces for conflict, and the method of engaging in conflict to achieve success. it is descriptive rather than prescriptive, requiring judgment in application." .

uaf:ProtocolLayer rdf:type owl:Class ;
            uaf:xmiID "2fd1ce5f-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Standards" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ProtocolLayer" ;
            rdfs:comment "Usage of a Protocol in the context of another Protocol. Creates a whole-part relationship." .

uaf:Project rdf:type owl:Class ;
            uaf:xmiID "31444ad7-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:OrganizationalResource ;
            rdfs:label "Project" ;
            rdfs:comment "A type that represents a planned endeavor executed by an ActualOrganization responsible for developing, deploying or decommissioning ResourcePerformers in accordance with ActualProjectMilestones." .

uaf:ProjectMilestone rdf:type owl:Class ;
            uaf:xmiID "324c923a-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Taxonomy" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "ProjectMilestone" ;
            rdfs:comment "A type of event in a Project by which progress is measured." .

uaf:ProjectSequence rdf:type owl:Class ;
            uaf:xmiID "352c335a-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:Sequence ;
            rdfs:label "ProjectSequence" ;
            rdfs:comment "A dependency relationship between two ActualProjects that denotes one ActualProject cannot start before the previous ActualProject is finished." .

uaf:MilestoneDependency rdf:type owl:Class ;
            uaf:xmiID "30c3f666-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Connectivity" ;
            rdfs:subClassOf uaf:Sequence ;
            rdfs:label "MilestoneDependency" ;
            rdfs:comment "A dependency relationship between two ActualProjectMilestones that denotes one ActualProjectMilestone follows from another." .

uaf:ProjectActivityAction rdf:type owl:Class ;
            uaf:xmiID "_18_4_1_8f40297_1481230875789_980040_37160" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:FunctionAction ;
            rdfs:label "ProjectActivityAction" ;
            rdfs:comment "The ProjectActivityAction is defined as a call behavior action that invokes the activity that needs to be preformed." .

uaf:ProjectActivity rdf:type owl:Class ;
            uaf:xmiID "_18_4_1_8f40297_1481224398051_761167_36538" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Processes" ;
            rdfs:subClassOf uaf:Function ;
            rdfs:label "ProjectActivity" ;
            rdfs:comment "An activity carried out during a project." .

uaf:ActualProjectMilestoneRole rdf:type owl:Class ;
            uaf:xmiID "35297414-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Roadmap" ;
            rdfs:subClassOf uaf:ActualState ;
            rdfs:label "ActualProjectMilestoneRole" ;
            rdfs:comment "An ActualProjectMilestone that is applied to a ProjectMilestoneRole." .

uaf:ActualProjectRole rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1414661712433_402502_29818" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Roadmap" ;
            rdfs:subClassOf uaf:ActualState ;
            rdfs:label "ActualProjectRole" ;
            rdfs:comment "An ActualProject that is applied to a ProjectRole." .

uaf:ActualProject rdf:type owl:Class ;
            uaf:xmiID "333ae9c9-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Roadmap" ;
            rdfs:subClassOf uaf:ActualOrganizationalResource ;
            rdfs:subClassOf uaf:Achiever ;
            rdfs:label "ActualProject" ;
            rdfs:comment "A time-limited planned endeavor executed by an ActualOrganization responsible for developing, deploying or decommissioning ResourcePerformers in accordance with ActualProjectMilestones." .

uaf:ActualProjectMilestone rdf:type owl:Class ;
            uaf:xmiID "3561e94d-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Roadmap" ;
            rdfs:subClassOf uaf:ActualPropertySet ;
            rdfs:label "ActualProjectMilestone" ;
            rdfs:comment "An event with a start date in a ActualProject from which progress is measured." .

uaf:ProjectRole rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1414661653455_672125_29807" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:ResourceRole ;
            rdfs:label "ProjectRole" ;
            rdfs:comment "Usage of a Project in the context of another Project. Creates a whole-part relationship." .

uaf:ProjectMilestoneRole rdf:type owl:Class ;
            uaf:xmiID "301fc75d-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ProjectMilestoneRole" ;
            rdfs:comment "The role played by a ProjectMilestone in the context of a Project." .

uaf:ProjectTheme rdf:type owl:Class ;
            uaf:xmiID "327290d3-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ProjectTheme" ;
            rdfs:comment "A property of a ProjectMilestone that captures an aspect by which the progress of ActualProjects may be measured." .

uaf:StatusIndicators rdf:type owl:Class ;
            uaf:xmiID "34cf6d53-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "StatusIndicators" ;
            rdfs:comment "An enumerated type that specifies a status for a ProjectTheme." .

uaf:ProjectStatus rdf:type owl:Class ;
            uaf:xmiID "35ac11b9-fbef-11e1-a364-456a62c2a10f" ;
            uaf:gridAspect "Projects" ;
            uaf:gridViewpoint "Structure" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "ProjectStatus" ;
            rdfs:comment "The status (i.e. level of progress) of a ProjectTheme for an ActualProject at the time of the ActualProjectMilestone." .

uaf:Architecture rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1415260890745_642894_30127" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "Architecture" ;
            rdfs:comment "An abstract type that represents a generic architecture. Subtypes are OperationalArchitecture, Service Architecture, and ResourceArchitecture." .

uaf:Stakeholder rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1415796220961_473714_30739" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "Stakeholder" ;
            rdfs:comment "An individual organizational resource, or a type of organizational resource (both internal and external to the enterprise) who has an interest in, or is affected by, outcomes or intermediate effects generated or influenced by the enterprise." .

uaf:UAFElement rdf:type owl:Class ;
            uaf:xmiID "30ff7903-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:label "UAFElement" ;
            rdfs:comment "Abstract super type for all of the UAF elements. It provides a way for all of the UAF elements to have a common set of properties. Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:Concern rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1415796492466_205113_30769" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:subClassOf uaf:PhaseableElement ;
            rdfs:label "Concern" ;
            rdfs:comment "A matter of relevance or importance to a stakeholder regarding an entity of interest." .

uaf:ArchitecturalDescription rdf:type owl:Class ;
            uaf:xmiID "3230581c-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "ArchitecturalDescription" ;
            rdfs:comment "An Architecture Description is a work product used to express the Architecture of some System Of Interest. It provides executive-level summary information about the architecture description in a consistent form to allow quick reference and comparison between architecture descriptions -- It includes assumptions, constraints, and limitations that may affect high-level decisions relating to an architecture-based work program." .

uaf:View rdf:type owl:Class ;
            uaf:xmiID "2f8caf84-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "View" ;
            rdfs:comment "An information item, governed by an architecture viewpoint, comprising part of an architecture description that communicates some aspect of an architecture." .

uaf:Viewpoint rdf:type owl:Class ;
            uaf:xmiID "2f0aae8b-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "Viewpoint" ;
            rdfs:comment "Conventions for the creation, interpretation and use of an architecture view to frame one or more concerns that governs the creation of views." .

uaf:Phases rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1613659880382_158152_930" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Phases" ;
            rdfs:comment "An abstraction relationship that exists between a PhaseableElement and an ActualStrategicPhase that it is assigned to." .

uaf:MeasurementSet rdf:type owl:Class ;
            uaf:xmiID "31996f46-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "MeasurementSet" ;
            rdfs:comment "A collection of Measurements." .

uaf:EnvironmentProperty rdf:type owl:Class ;
            uaf:xmiID "3094a984-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "EnvironmentProperty" ;
            rdfs:comment "A property of an Environment that is typed by a  Condition.  The kinds of Condition that can be represented are Location, GeoPoliticalExtentType and Environment." .

uaf:MeasurableElement rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1415869306050_312434_34035" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "MeasurableElement" ;
            rdfs:comment "Abstract grouping for elements that can be measured by applying MeasurementSets to them. Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:ActualCondition rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_7d40257_1418067173099_600790_44455" ;
            rdfs:subClassOf uaf:ActualPropertySet ;
            rdfs:label "ActualCondition" ;
            rdfs:comment "An actual situation with respect to circumstances under which an OperationalActivity, Function or ServiceFunction can be performed." .

uaf:Measurement rdf:type owl:Class ;
            uaf:xmiID "33e9794f-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Measurement" ;
            rdfs:comment "A property of an element representing something in the physical world, expressed in amounts of a unit of measure." .

uaf:GeoPoliticalExtentType rdf:type owl:Class ;
            uaf:xmiID "349ff843-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:ResourceExchangeItem ;
            rdfs:subClassOf uaf:OperationalExchangeItem ;
            rdfs:subClassOf uaf:Condition ;
            rdfs:subClassOf uaf:StrategicExchangeItem ;
            rdfs:label "GeoPoliticalExtentType" ;
            rdfs:comment "A type of geospatial extent whose boundaries are defined by declaration or agreement by political parties." .

uaf:ActualMeasurement rdf:type owl:Class ;
            uaf:xmiID "2f17cd8b-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:ActualState ;
            rdfs:label "ActualMeasurement" ;
            rdfs:comment "An actual value that is applied to a Measurement." .

uaf:ActualEnvironment rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_7d40257_1418066967938_554688_44408" ;
            rdfs:subClassOf uaf:ActualCondition ;
            rdfs:label "ActualEnvironment" ;
            rdfs:comment "Actual circumstances of an Environment." .

uaf:Location rdf:type owl:Class ;
            uaf:xmiID "2fdaf69e-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:ConceptItem ;
            rdfs:subClassOf uaf:Condition ;
            rdfs:label "Location" ;
            rdfs:comment "A specification of the generic area in which a LocationHolder is required to be located." .

uaf:Condition rdf:type owl:Class ;
            uaf:xmiID "35b62369-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "Condition" ;
            rdfs:comment "A type that defines the Location, Environment and/or GeoPoliticalExtent." .

uaf:PropertySet rdf:type owl:Class ;
            uaf:xmiID "331b05f8-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "PropertySet" ;
            rdfs:comment "An abstract grouping of architectural elements that can own Measurements. Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:ActualMeasurementSet rdf:type owl:Class ;
            uaf:xmiID "_18_0_2_90d02a1_1415869956288_423061_34111" ;
            rdfs:subClassOf uaf:ActualPropertySet ;
            rdfs:label "ActualMeasurementSet" ;
            rdfs:comment "A set of ActualMeasurements." .

uaf:ActualPropertySet rdf:type owl:Class ;
            uaf:xmiID "30f76343-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:ActualState ;
            rdfs:label "ActualPropertySet" ;
            rdfs:comment "A set or collection of Actual properties." .

uaf:LocationHolder rdf:type owl:Class ;
            uaf:xmiID "32f83bee-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "LocationHolder" ;
            rdfs:comment "Abstract grouping used to define elements that are allowed to be associated with a Location. Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:ActualLocation rdf:type owl:Class ;
            uaf:xmiID "3455cfe1-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:ActualCondition ;
            rdfs:label "ActualLocation" ;
            rdfs:comment "A physical location, for example using text to provide an address, Geo-coordinates, etc." .

uaf:Environment rdf:type owl:Class ;
            uaf:xmiID "32d746a2-fbef-11e1-a364-456a62c2a10f" ;
            rdfs:subClassOf uaf:Condition ;
            rdfs:label "Environment" ;
            rdfs:comment "A definition of the environmental factors in which something exists or functions. The definition of an Environment element can be further defined using  EnvironmentKind." .

uaf:AffectableElement rdf:type owl:Class ;
            uaf:xmiID "_19_0_4_3ed017a_1619180702842_29081_91" ;
            rdfs:subClassOf uaf:UAFElement ;
            rdfs:label "AffectableElement" ;
            rdfs:comment "An abstract grouping of elements that can be affected by Risk. Note: Classified as a Mixin Class (Solution 2) to resolve disjointness conflicts." .

uaf:Risk rdf:type owl:Class ;
            uaf:xmiID "_18_1_8f40297_1442869344830_26700_45611" ;
            rdfs:subClassOf uaf:PropertySet ;
            rdfs:label "Risk" ;
            rdfs:comment "A type that represents a situation involving exposure to danger of AffectableElements (e.g. Assets, Processes, Capabilities, Opportunities, or Enterprise Goals) where the effects of such exposure can be characterized in terms of the likelihood of occurrence of a given threat and the potential adverse consequences of that threat's occurrence." .

uaf:OwnsRiskInContext rdf:type owl:Class ;
            uaf:xmiID "_18_4_1_8f40297_1490865030708_506887_44732" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "OwnsRiskInContext" ;
            rdfs:comment "An abstraction relating a Risk to an organizational role that is responsible for executing the risk mitigation in the specific context or configuration." .

uaf:OwnsRisk rdf:type owl:Class ;
            uaf:xmiID "_18_2_8f40297_1458162742651_123245_52271" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "OwnsRisk" ;
            rdfs:comment "An abstraction relating a Risk to an organizational resource that is responsible for executing the risk mitigation." .

uaf:Mitigates rdf:type owl:Class ;
            uaf:xmiID "_18_2_8f40297_1458162702673_152936_52244" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Mitigates" ;
            rdfs:comment "A dependency relating a Security Control to a Risk. Mitigation is established to manage risk and could be represented as an overall strategy or through techniques (mitigation configurations) and procedures (SecurityProcesses)." .

uaf:Affects rdf:type owl:Class ;
            uaf:xmiID "_18_2_8f40297_1458162673338_259553_52217" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "Affects" ;
            rdfs:comment "A dependency that asserts that a Risk is applicable to an Asset." .

uaf:AffectsInContext rdf:type owl:Class ;
            uaf:xmiID "_18_4_1_8f40297_1490858650298_851053_44501" ;
            rdfs:subClassOf uaf:MeasurableElement ;
            rdfs:label "AffectsInContext" ;
            rdfs:comment "A dependency that asserts that a Risk is applicable to an AssetRole in the specific context or configuration." .

uaf:ActualRisk rdf:type owl:Class ;
            uaf:xmiID "_18_2_8f40297_1458160194147_693430_49839" ;
            rdfs:subClassOf uaf:ActualPropertySet ;
            rdfs:label "ActualRisk" ;
            rdfs:comment "An instance of a Risk. A value holder for Risk Measurements." .

uaf:MissionVignette rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1715343801704_246695_889" ;
            rdfs:subClassOf uaf:Condition ;
            rdfs:label "MissionVignette" ;
            rdfs:comment "Description of the geographical location and time frame of the overall conflict. A vignette includes information such as threat and friendly politico-military contexts and backgrounds, assumptions, constraints, limitations, strategic objectives, and other planning considerations. It can represent small, ideally self-contained parts of a scenario. (OUSD(R&E))" .

uaf:MissionScenario rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1715343753939_708925_864" ;
            rdfs:subClassOf uaf:Condition ;
            rdfs:label "MissionScenario" ;
            rdfs:comment "Description of the geographical location and time frame of the overall conflict. A scenario includes information such as threat and friendly politico-military contexts and backgrounds, assumptions, constraints, limitations, strategic objectives, and other planning considerations. (OUSD(R&E))" .

uaf:ActualMissionVignette rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1715344095682_850752_1285" ;
            rdfs:subClassOf uaf:ActualCondition ;
            rdfs:label "ActualMissionVignette" ;
            rdfs:comment "A particular Mission Vignette within which an Actual Mission is to be accomplished" .

uaf:ActualMissionScenario rdf:type owl:Class ;
            uaf:xmiID "_2022x_2_2cd011a_1715344174994_611868_1319" ;
            rdfs:subClassOf uaf:ActualCondition ;
            rdfs:label "ActualMissionScenario" ;
            rdfs:comment "A particular Mission Scenario within which an Actual Mission is to be accomplished" .

