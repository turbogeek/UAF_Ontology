# --- Information Content Entity (ICE) Framework ---

uaf:InformationContentEntity rdf:type owl:Class ;
            rdfs:subClassOf gufo:AbstractIndividual ;
            rdfs:label "Information Content Entity" ;
            rdfs:comment "An entity that represents information content (ICE), such as a message, document, or schema." .

uaf:Message rdfs:subClassOf uaf:InformationContentEntity .

uaf:Schema rdf:type owl:Class ;
            rdfs:subClassOf uaf:InformationContentEntity ;
            rdfs:label "Schema" ;
            rdfs:comment "A schema that describes the structure of data." .

uaf:DesignEvent rdf:type owl:Class ;
            rdfs:subClassOf gufo:Event ;
            rdfs:label "Design Event" ;
            rdfs:comment "An event during which a schema or architecture is designed." .

uaf:carriesDataThatRepresents rdf:type owl:ObjectProperty ;
            rdfs:domain uaf:Message ;
            rdfs:range gufo:Event ;
            rdfs:label "carries data that represents" ;
            rdfs:comment "Relates a message to the event whose data it carries." .

uaf:conformsTo rdf:type owl:ObjectProperty ;
            rdfs:domain uaf:Message ;
            rdfs:range uaf:Schema ;
            rdfs:label "conforms to" ;
            rdfs:comment "Relates a message to the schema it conforms to." .

uaf:wasResultOf rdf:type owl:ObjectProperty ;
            rdfs:domain uaf:Schema ;
            rdfs:range uaf:DesignEvent ;
            rdfs:label "was result of" ;
            rdfs:comment "Relates a schema to the design event that produced it." .

# Restrictions
uaf:Message rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty uaf:carriesDataThatRepresents ;
    owl:someValuesFrom gufo:Event
] .

uaf:Schema rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty uaf:wasResultOf ;
    owl:someValuesFrom uaf:DesignEvent
] .