@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gufo: <http://purl.org/nemo/gufo#> .
@prefix kerml: <http://omg.org/spec/KerML#> .
@prefix sysml2: <http://omg.org/spec/SysML2#> .
@prefix uafsml: <http://purl.org/uaf/uafsml#> .

<http://purl.org/uaf/uafsml> rdf:type owl:Ontology ;
    owl:imports <http://purl.org/nemo/gufo> ,
                <http://omg.org/spec/KerML> ,
                <http://omg.org/spec/SysML2> ;
    rdfs:label "UAFSML 2.0 (UAF for SysML v2) Ontology" ;
    rdfs:comment "OWL representation of the UAF 2.0 (UAFSML) library definitions and viewpoints inheriting from standard SysML v2 and KerML." .

# --- Metamodel Core Inheritance ---

uafsml:Element rdf:type owl:Class ;
    rdfs:subClassOf kerml:Element ;
    rdfs:label "Element" .

uafsml:Definition rdf:type owl:Class ;
    rdfs:subClassOf kerml:Definition ;
    rdfs:label "Definition" .

uafsml:Usage rdf:type owl:Class ;
    rdfs:subClassOf kerml:Usage ;
    rdfs:label "Usage" .


uafsml:lib-abstract-grid rdf:type owl:Class ;
    rdfs:subClassOf uafsml:Definition ;
    rdfs:label "Abstract Grid" ;
    sysml2:canonical "Abstract Grid" ;
    rdfs:comment "Library package defined in Abstract Grid.sysml" .

uafsml:def-grid rdf:type owl:Class ;
    rdfs:subClassOf sysml2:def-viewpointdefinition ;
    rdfs:label "Grid" ;
    sysml2:canonical "Abstract Grid::Grid" ;
    rdfs:comment "SysML v2 viewpoint def definition: 'Grid'" .

uafsml:def-gridrow rdf:type owl:Class ;
    rdfs:subClassOf sysml2:def-viewpointdefinition ;
    rdfs:label "GridRow" ;
    sysml2:canonical "Abstract Grid::GridRow" ;
    rdfs:comment "SysML v2 viewpoint def definition: 'GridRow'" .

