<?xml version="1.0" encoding="UTF-8"?>
<!-- Template descriptor. The deployed copy is generated by the Gradle deployPlugin task,
     which appends the bundled runtime jars (Jena, JavaFX) as <library> entries.
     ownClassloader isolates Jena/JavaFX from Cameo's own libraries to avoid SPI clashes. -->
<plugin id="com.nomagic.magicdraw.plugins.semantic"
        name="UAF and SysML Semantic Integration Plugin"
        version="2.2.0"
        provider-name="NoMagic"
        class="com.nomagic.magicdraw.plugins.semantic.SemanticAlignmentPlugin"
        ownClassloader="true">
    <requires>
        <api version="1.0"/>
        <!-- Supplies the Groovy runtime for the integrated REST test harness -->
        <required-plugin id="AutomatonPlugin" name="Automaton"/>
    </requires>
    <runtime>
        <library name="semantic-alignment-plugin.jar"/>
    </runtime>
</plugin>
