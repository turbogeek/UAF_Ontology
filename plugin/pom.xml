<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.nomagic.magicdraw.plugins</groupId>
    <artifactId>semantic-alignment-plugin</artifactId>
    <version>2.2.0</version>
    <packaging>jar</packaging>

    <name>UAF / SysML Semantic Alignment Plugin</name>
    <description>Integrates systems engineering models with EMMO, SUMO, BMM, and W3C ORG ontologies.</description>

    <properties>
        <!-- Kept in sync with the Gradle toolchain and the Cameo-bundled Temurin 21 JRE -->
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <!-- Default local install directory, customizable by builder -->
        <cameo.install.dir>E:/Magic SW/CMSoS26xR1pr</cameo.install.dir>
    </properties>

    <dependencies>
        <!-- Cameo / MagicDraw Core Libraries (System Scope for local compilation) -->
        <dependency>
            <groupId>com.nomagic.magicdraw</groupId>
            <artifactId>md-core</artifactId>
            <version>26.1.0</version>
            <scope>system</scope>
            <systemPath>${cameo.install.dir}/lib/md.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>com.nomagic.magicdraw</groupId>
            <artifactId>md-api</artifactId>
            <version>26.1.0</version>
            <scope>system</scope>
            <systemPath>${cameo.install.dir}/lib/md_api.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>com.nomagic.magicdraw</groupId>
            <artifactId>md-common</artifactId>
            <version>26.1.0</version>
            <scope>system</scope>
            <systemPath>${cameo.install.dir}/lib/md_common.jar</systemPath>
        </dependency>

        <!-- Apache Jena for RDF/Turtle generation -->
        <dependency>
            <groupId>org.apache.jena</groupId>
            <artifactId>jena-core</artifactId>
            <version>4.6.1</version>
        </dependency>
        <dependency>
            <groupId>org.apache.jena</groupId>
            <artifactId>jena-shacl</artifactId>
            <version>4.6.1</version>
        </dependency>

        <!-- Testing Framework -->
        <dependency>
            <groupId>junit</groupId>
            <artifactId>junit</artifactId>
            <version>4.13.2</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- Java Compiler Plugin (Targeting Java 12 Switch Expressions) -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.8.1</version>
                <configuration>
                    <source>${maven.compiler.source}</source>
                    <target>${maven.compiler.target}</target>
                    <!-- No --enable-preview: preview-flagged classes refuse to load in
                         Cameo's JVM, which is not started with that flag. -->
                </configuration>
            </plugin>

            <!-- Linter Checkstyle Integration -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-checkstyle-plugin</artifactId>
                <version>3.1.2</version>
                <configuration>
                    <configLocation>google_checks.xml</configLocation>
                    <failOnViolation>true</failOnViolation>
                    <violationSeverity>warning</violationSeverity>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
